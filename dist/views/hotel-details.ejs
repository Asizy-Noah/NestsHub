<div x-data="hotelDetails(<%= typeof payload !== 'undefined' ? payload : '{}' %>)" class="bg-slate-50 dark:bg-dark-bg min-h-screen pb-24 sm:pb-8" x-cloak>
    
    <div class="relative w-full h-[40vh] sm:h-[60vh] bg-slate-200 dark:bg-slate-900 group overflow-hidden">
        <div class="flex h-full w-full overflow-x-auto snap-x snap-mandatory hide-scrollbar" @scroll="updateActiveImage($event)">
            <template x-for="(img, index) in allPhotos" :key="index">
                <div class="w-full h-full flex-shrink-0 snap-center relative">
                    <img :src="img" class="w-full h-full object-cover cursor-pointer" @click="openGallery(index)">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20 pointer-events-none"></div>
                </div>
            </template>
            <div x-show="allPhotos.length === 0" class="w-full h-full flex items-center justify-center text-slate-400">
                <i class="fa-solid fa-hotel text-6xl"></i>
            </div>
        </div>

        <div class="absolute top-0 inset-x-0 p-4 flex justify-between items-start z-10">
            <button @click="history.back()" class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors shadow-sm">
                <i class="fa-solid fa-arrow-left"></i>
            </button>
            <div class="flex gap-2">
                <button class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors shadow-sm"><i class="fa-solid fa-share-nodes"></i></button>
                <button @click="toggleSave()" class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors shadow-sm"><i class="fa-solid fa-heart" :class="isSaved ? 'text-red-500' : ''"></i></button>
            </div>
        </div>

        <div x-show="allPhotos.length > 1" class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md text-white text-xs font-black px-3 py-1.5 rounded-full z-10 shadow-sm flex items-center gap-2">
            <i class="fa-regular fa-image"></i> <span x-text="`${activeImageIndex + 1} / ${allPhotos.length}`"></span>
        </div>
        <div x-show="hotel.isVerified" class="absolute bottom-4 left-4 bg-primary/90 backdrop-blur-md text-white text-[10px] uppercase font-black px-3 py-1.5 rounded-full z-10 shadow-lg flex items-center gap-1">
            <i class="fa-solid fa-shield-check"></i> Verified Hotel
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-20">
        
        <div class="bg-white dark:bg-dark-surface rounded-3xl shadow-glass p-6 sm:p-8 mb-6 border border-slate-100 dark:border-slate-800">
            <div class="flex justify-between items-start mb-2">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-black text-professional dark:text-white leading-tight mb-2" x-text="room.type"></h1>
                    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 flex items-center gap-2">
                        <i class="fa-solid fa-map-location-dot text-slate-300"></i>
                        <span x-text="hotel.name + ' • ' + (hotel.street || '') + ', ' + (hotel.districtOrCity || hotel.town || '')"></span>
                    </p>
                </div>
            </div>
            
            <div class="mt-6 pt-6 border-t border-slate-100 dark:border-slate-800 flex items-end justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Rate</p>
                    <div class="flex items-baseline gap-1 text-primary">
                        <span class="text-xl font-bold">UGX</span>
                        <span class="text-3xl sm:text-4xl font-black" x-text="Number(room.price).toLocaleString()"></span>
                    </div>
                    <p class="text-xs font-bold text-slate-500 mt-1 uppercase">Per Night</p>
                </div>
                <div class="text-right flex flex-col items-end">
                    <span class="inline-block px-3 py-1 rounded-lg text-xs font-black uppercase tracking-wider mb-1" 
                          :class="room.availableRooms > 0 ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'"
                          x-text="room.availableRooms > 0 ? 'Available' : 'Sold Out'"></span>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2 space-y-6">
                
                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-6">Room Features</h3>
                    <div class="grid grid-cols-2 gap-y-6 gap-x-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-primary"><i class="fa-solid fa-bed"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Bed Type</p><p class="text-sm font-bold text-professional dark:text-white" x-text="room.bedSize || 'Standard'"></p></div>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center" :class="room.bedAndBreakfast ? 'text-primary' : 'text-slate-400'"><i class="fa-solid fa-mug-hot"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Meals</p><p class="text-sm font-bold text-professional dark:text-white" x-text="room.bedAndBreakfast ? 'Breakfast Included' : 'Room Only'"></p></div>
                        </div>
                        <div class="flex items-center gap-3" x-show="room.hasAC">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-primary"><i class="fa-solid fa-snowflake"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Climate</p><p class="text-sm font-bold text-professional dark:text-white">Air Conditioned</p></div>
                        </div>
                        <div class="flex items-center gap-3" x-show="room.hotWater">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-primary"><i class="fa-solid fa-shower"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Bathroom</p><p class="text-sm font-bold text-professional dark:text-white">Hot Water</p></div>
                        </div>
                        <div class="flex items-center gap-3" x-show="room.hasTV">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-primary"><i class="fa-solid fa-tv"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Entertainment</p><p class="text-sm font-bold text-professional dark:text-white">Smart TV / DSTV</p></div>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-hotel text-primary"></i> About <span x-text="hotel.name"></span>
                    </h3>
                    <h4 class="text-sm font-bold text-slate-700 dark:text-slate-300 mb-4">Hotel Facilities</h4>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 gap-x-2">
                        <template x-for="(value, key) in hotel.amenities" :key="key">
                            <div x-show="value" class="flex items-center gap-2 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                <i class="fa-solid fa-circle-check text-primary text-[10px]"></i>
                                <span class="capitalize" x-text="key.replace(/([A-Z])/g, ' $1').trim()"></span>
                            </div>
                        </template>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="sticky top-24 space-y-6">
                    <div class="bg-white dark:bg-dark-surface rounded-3xl p-4 shadow-glass border border-slate-100 dark:border-slate-800 flex flex-col gap-3">
                        <a :href="`tel:${managerProfile.phones[0]}`" class="btn-primary w-full py-4 text-base shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                            <i class="fa-solid fa-phone-volume"></i> Call Reception
                        </a>
                        <div class="flex gap-3">
                            <a :href="`https://wa.me/${managerProfile.whatsapps[0]}`" target="_blank" class="flex-1 bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366] hover:text-white rounded-xl py-3 flex items-center justify-center gap-2 font-bold transition-colors">
                                <i class="fa-brands fa-whatsapp text-lg"></i> WhatsApp
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function hotelDetails(serverData) {
    const room = serverData?.room || {};
    const hotel = serverData?.hotel || {};
    const manager = serverData?.managerProfile || {};

    return {
        room: Object.assign({ type: 'Standard', price: 0, availableRooms: 0, photos: [] }, room),
        hotel: Object.assign({ name: 'Hotel', phones: [''], whatsapps: [''], gallery: [], amenities: {} }, hotel),
        managerProfile: Object.assign({ firstName: 'Management', lastName: '', photo: '', phones: [''], whatsapps: [''] }, manager),
        
        allPhotos: [...(room.photos || []), ...(hotel.gallery || [])],
        activeImageIndex: 0, galleryOpen: false, isSaved: false, showMobileContact: false,

        init() { window.addEventListener('scroll', () => { this.showMobileContact = window.scrollY > 300; }); },
        updateActiveImage(e) { this.activeImageIndex = Math.round(e.target.scrollLeft / e.target.offsetWidth); },
        openGallery(index) { this.activeImageIndex = index; this.galleryOpen = true; },
        toggleSave() { this.isSaved = !this.isSaved; }
    }
}
</script>