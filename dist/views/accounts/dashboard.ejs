<%- include('../layout', { title, body: `
<div class="max-w-7xl mx-auto px-4 py-12" x-data="dashboard()" x-cloak>
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold">Dashboard</h1>
        <div class="flex gap-2">
            <a href="/accounts/profile" class="btn-secondary">Edit Profile</a>
            <button @click="logout()" class="btn-primary">Logout</button>
        </div>
    </div>

    <!-- User Info Card -->
    <div class="card mb-8">
        <div class="flex items-start justify-between">
            <div>
                <h2 class="text-2xl font-bold" x-text="user?.firstName + ' ' + user?.lastName"></h2>
                <p class="text-gray-600 dark-mode:text-gray-400" x-text="user?.email"></p>
                <p class="text-sm text-gray-500 dark-mode:text-gray-500 mt-2">
                    Role: <span class="font-medium" x-text="user?.role?.replace(/_/g, ' ').toUpperCase()"></span>
                </p>
            </div>
            <div class="text-right">
                <p class="text-gray-600 dark-mode:text-gray-400 text-sm">Member since</p>
                <p class="text-lg font-medium" x-text="memberSince"></p>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="card hover:shadow-lg transition-shadow cursor-pointer">
            <h3 class="text-lg font-bold mb-2">My Profile</h3>
            <p class="text-gray-600 dark-mode:text-gray-400 text-sm mb-4">
                View and edit your profile information
            </p>
            <a href="/accounts/profile" class="text-blue-600 hover:underline text-sm">
                Go to Profile →
            </a>
        </div>

        <div class="card hover:shadow-lg transition-shadow cursor-pointer">
            <h3 class="text-lg font-bold mb-2">Settings</h3>
            <p class="text-gray-600 dark-mode:text-gray-400 text-sm mb-4">
                Manage your account settings and preferences
            </p>
            <a href="/accounts/settings" class="text-blue-600 hover:underline text-sm">
                Go to Settings →
            </a>
        </div>

        <div class="card hover:shadow-lg transition-shadow cursor-pointer">
            <h3 class="text-lg font-bold mb-2">Help & Support</h3>
            <p class="text-gray-600 dark-mode:text-gray-400 text-sm mb-4">
                Get help or contact our support team
            </p>
            <a href="#" class="text-blue-600 hover:underline text-sm">
                Contact Support →
            </a>
        </div>
    </div>

    <!-- Activities -->
    <div class="card">
        <h2 class="text-xl font-bold mb-4">Recent Activities</h2>
        <div class="space-y-4">
            <div class="flex items-center justify-between p-4 bg-gray-50 dark-mode:bg-gray-700 rounded-lg">
                <div>
                    <p class="font-medium">Account Created</p>
                    <p class="text-sm text-gray-600 dark-mode:text-gray-400">You created your account</p>
                </div>
                <span class="text-sm text-gray-500" x-text="createdAt"></span>
            </div>
            <div class="flex items-center justify-between p-4 bg-gray-50 dark-mode:bg-gray-700 rounded-lg">
                <div>
                    <p class="font-medium">Email Verified</p>
                    <p class="text-sm text-gray-600 dark-mode:text-gray-400">Your email address was verified</p>
                </div>
                <span class="text-sm text-gray-500">Today</span>
            </div>
        </div>
    </div>
</div>

<script>
function dashboard() {
    return {
        user: null,
        memberSince: '',
        createdAt: '',

        init() {
            const user = localStorage.getItem('user');
            if (user) {
                this.user = JSON.parse(user);
                this.memberSince = new Date().toLocaleDateString();
                this.createdAt = new Date().toLocaleDateString();
            }
        },

        logout() {
            localStorage.removeItem('accessToken');
            localStorage.removeItem('user');
            window.location.href = '/auth/login';
        },

        init() {
            this.init();
        },
    };
}
</script>
`) %>
