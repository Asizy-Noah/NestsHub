<div x-data="propertyDetails()" class="bg-slate-50 dark:bg-dark-bg min-h-screen pb-24 sm:pb-8" x-cloak>
    
    <div class="relative w-full h-[40vh] sm:h-[60vh] bg-slate-200 dark:bg-slate-900 group overflow-hidden">
        
        <div class="flex h-full w-full overflow-x-auto snap-x snap-mandatory hide-scrollbar" @scroll="updateActiveImage($event)">
            <template x-for="(img, index) in allPhotos" :key="index">
                <div class="w-full h-full flex-shrink-0 snap-center relative">
                    <img :src="img" class="w-full h-full object-cover cursor-pointer" @click="openGallery(index)">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20 pointer-events-none"></div>
                </div>
            </template>
            <div x-show="allPhotos.length === 0" class="w-full h-full flex items-center justify-center text-slate-400">
                <i class="fa-solid fa-building-columns text-6xl"></i>
            </div>
        </div>

        <div class="absolute top-0 inset-x-0 p-4 flex justify-between items-start z-10">
            <button @click="history.back()" class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors">
                <i class="fa-solid fa-arrow-left"></i>
            </button>
            <div class="flex gap-2">
                <button class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors">
                    <i class="fa-solid fa-share-nodes"></i>
                </button>
                <button @click="toggleSave()" class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors">
                    <i class="fa-solid fa-heart" :class="isSaved ? 'text-red-500' : ''"></i>
                </button>
            </div>
        </div>

        <div x-show="allPhotos.length > 1" class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md text-white text-xs font-black px-3 py-1.5 rounded-full z-10 shadow-sm flex items-center gap-2">
            <i class="fa-regular fa-image"></i> <span x-text="`${activeImageIndex + 1} / ${allPhotos.length}`"></span>
        </div>

        <div x-show="hostel.isVerified" class="absolute bottom-4 left-4 bg-primary/90 backdrop-blur-md text-white text-[10px] uppercase font-black px-3 py-1.5 rounded-full z-10 shadow-lg flex items-center gap-1">
            <i class="fa-solid fa-shield-check"></i> Verified Property
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-20">
        
        <div class="bg-white dark:bg-dark-surface rounded-3xl shadow-glass p-6 sm:p-8 mb-6 border border-slate-100 dark:border-slate-800">
            <div class="flex justify-between items-start mb-2">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-black text-professional dark:text-white leading-tight mb-2" x-text="room.type + ' Room'"></h1>
                    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 flex items-center gap-2">
                        <i class="fa-solid fa-location-dot text-slate-300"></i>
                        <span x-text="hostel.name + ' • ' + hostel.popularAreaName + ', ' + hostel.locationName"></span>
                    </p>
                </div>
            </div>
            
            <div class="mt-6 pt-6 border-t border-slate-100 dark:border-slate-800 flex items-end justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Rental Rate</p>
                    <div class="flex items-baseline gap-1 text-primary">
                        <span class="text-xl font-bold">UGX</span>
                        <span class="text-3xl sm:text-4xl font-black" x-text="room.price.toLocaleString()"></span>
                    </div>
                    <p class="text-xs font-bold text-slate-500 mt-1 uppercase" x-text="room.pricingPeriod"></p>
                </div>
                
                <div class="text-right">
                    <span class="inline-block px-3 py-1 rounded-lg text-xs font-black uppercase tracking-wider mb-1" 
                          :class="room.availableRooms > 0 ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'"
                          x-text="room.availableRooms > 0 ? 'Available' : 'Sold Out'"></span>
                    <p class="text-[10px] font-bold text-slate-400"><span x-text="room.availableRooms"></span> of <span x-text="room.totalRooms"></span> units left</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            <div class="md:col-span-2 space-y-6">
                
                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-4">About this Room</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed" x-text="generateRoomDescription()"></p>
                </div>

                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-6">Room Specifications</h3>
                    
                    <div class="grid grid-cols-2 gap-y-6 gap-x-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-400"><i class="fa-solid fa-layer-group"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Floor Level</p><p class="text-sm font-bold text-professional dark:text-white" x-text="room.floorLevel"></p></div>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-400" :class="room.isSelfContained ? 'text-primary' : ''"><i class="fa-solid fa-bath"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Bathroom</p><p class="text-sm font-bold text-professional dark:text-white" x-text="room.isSelfContained ? 'Self Contained' : 'Shared'"></p></div>
                        </div>
                        <div class="flex items-center gap-3" x-show="room.hasBalcony">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-primary"><i class="fa-solid fa-cloud-sun"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">View</p><p class="text-sm font-bold text-professional dark:text-white">Private Balcony</p></div>
                        </div>
                        <div class="flex items-center gap-3" x-show="room.hasAC">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-primary"><i class="fa-solid fa-fan"></i></div>
                            <div><p class="text-[10px] font-bold text-slate-400 uppercase">Climate</p><p class="text-sm font-bold text-professional dark:text-white">Air Conditioning</p></div>
                        </div>
                    </div>

                    <div class="mt-6 pt-6 border-t border-slate-100 dark:border-slate-800" x-show="room.cookingMethods && room.cookingMethods.length > 0">
                        <p class="text-xs font-bold text-slate-500 mb-3">Allowed Cooking Methods</p>
                        <div class="flex flex-wrap gap-2">
                            <template x-for="method in room.cookingMethods">
                                <span class="px-3 py-1.5 bg-slate-100 dark:bg-slate-800 rounded-lg text-xs font-bold text-slate-600 dark:text-slate-300" x-text="method"></span>
                            </template>
                        </div>
                    </div>

                    <div class="mt-6 pt-6 border-t border-slate-100 dark:border-slate-800" x-show="room.isFurnished">
                        <p class="text-xs font-bold text-slate-500 mb-3">Included Furniture</p>
                        <div class="flex flex-wrap gap-2">
                            <template x-for="item in room.furniture">
                                <span class="px-3 py-1.5 bg-primary/10 text-primary rounded-lg text-xs font-bold" x-text="item"></span>
                            </template>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-building text-primary"></i> About <span x-text="hostel.name"></span>
                    </h3>
                    
                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-4 rounded-2xl">
                            <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Distance to Campus/Town</p>
                            <p class="text-sm font-black text-professional dark:text-white" x-text="hostel.distance + ' Meters'"></p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-4 rounded-2xl">
                            <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Environment</p>
                            <p class="text-sm font-black text-professional dark:text-white" x-text="hostel.locationType + ' Zone'"></p>
                        </div>
                    </div>

                    <h4 class="text-sm font-bold text-slate-700 dark:text-slate-300 mb-4">Hostel Amenities</h4>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 gap-x-2">
                        <template x-for="(value, key) in hostel.amenities" :key="key">
                            <div x-show="value" class="flex items-center gap-2 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                <i class="fa-solid fa-circle-check text-primary text-[10px]"></i>
                                <span class="capitalize" x-text="key.replace(/([A-Z])/g, ' $1').trim()"></span>
                            </div>
                        </template>
                    </div>
                </div>
                
                <div class="bg-amber-50 dark:bg-amber-900/10 rounded-3xl p-6 sm:p-8 border border-amber-100 dark:border-amber-900/30">
                    <h3 class="text-sm font-black text-amber-600 dark:text-amber-500 mb-3 flex items-center gap-2"><i class="fa-solid fa-shield-halved"></i> Safety Tips</h3>
                    <ul class="text-xs text-amber-700/80 dark:text-amber-400/80 space-y-2 font-medium">
                        <li>• Do not pay any money before inspecting the property physically.</li>
                        <li>• Meet the manager at the exact hostel location provided.</li>
                        <li>• Verify payment procedures with the official hostel administration.</li>
                    </ul>
                </div>
            </div>

            <div class="space-y-6">
                <div class="sticky top-24 space-y-6">
                    
                    <div class="bg-white dark:bg-dark-surface rounded-3xl p-4 shadow-glass border border-slate-100 dark:border-slate-800 flex flex-col gap-3">
                        <a :href="`tel:${hostel.phones[0]}`" class="btn-primary w-full py-4 text-base shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                            <i class="fa-solid fa-phone-volume"></i> Call Manager
                        </a>
                        <div class="flex gap-3">
                            <a :href="`https://wa.me/${hostel.whatsapps[0]}`" target="_blank" class="flex-1 bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366] hover:text-white rounded-xl py-3 flex items-center justify-center gap-2 font-bold transition-colors">
                                <i class="fa-brands fa-whatsapp text-lg"></i> WhatsApp
                            </a>
                            <button @click="openMessageModal()" class="flex-1 bg-slate-100 dark:bg-slate-800 text-professional dark:text-white hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl py-3 flex items-center justify-center gap-2 font-bold transition-colors">
                                <i class="fa-regular fa-comment-dots text-lg"></i> Message
                            </button>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 border border-slate-100 dark:border-slate-800 shadow-sm text-center">
                        <div class="w-20 h-20 mx-auto rounded-full bg-slate-100 dark:bg-slate-800 border-4 border-white dark:border-dark-surface shadow-md overflow-hidden mb-3 relative">
                            <img :src="managerProfile.photo || 'https://ui-avatars.com/api/?name=' + managerProfile.firstName" class="w-full h-full object-cover">
                            <div x-show="hostel.isVerified" class="absolute bottom-0 right-0 w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center text-[10px] border-2 border-white"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <h4 class="font-black text-professional dark:text-white text-lg" x-text="managerProfile.firstName + ' ' + managerProfile.lastName"></h4>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4" x-text="managerProfile.role.replace('_', ' ')"></p>
                        
                        <div class="flex justify-center gap-4 py-4 border-y border-slate-50 dark:border-slate-800/50 mb-4">
                            <div><p class="text-lg font-black text-professional dark:text-white" x-text="hostel.roomsCount"></p><p class="text-[10px] font-bold text-slate-400 uppercase">Rooms</p></div>
                            <div class="w-px bg-slate-100 dark:bg-slate-800"></div>
                            <div><p class="text-lg font-black text-professional dark:text-white flex items-center justify-center gap-1"><span x-text="reviews.avgRating"></span><i class="fa-solid fa-star text-amber-400 text-[10px]"></i></p><p class="text-[10px] font-bold text-slate-400 uppercase"><span x-text="reviews.total"></span> Reviews</p></div>
                        </div>
                        
                        <div class="text-left bg-slate-50 dark:bg-slate-800/50 p-3 rounded-xl relative">
                            <i class="fa-solid fa-quote-left absolute text-slate-200 dark:text-slate-700 text-2xl -top-2 -left-1"></i>
                            <p class="text-xs text-slate-600 dark:text-slate-300 font-medium italic relative z-10 line-clamp-3" x-text="reviews.latest.comment"></p>
                            <p class="text-[10px] font-bold text-slate-400 mt-2 text-right" x-text="'- ' + reviews.latest.author"></p>
                        </div>
                        
                        <a href="#reviews" class="block mt-4 text-xs font-bold text-primary hover:underline">Read All Reviews</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
            <h3 class="text-xl font-black text-professional dark:text-white mb-6">Similar Hostels in <span x-text="hostel.locationName"></span></h3>
            <div class="flex gap-4 overflow-x-auto hide-scrollbar pb-4">
                <template x-for="item in similarProperties" :key="item.id">
                    <div class="w-64 flex-shrink-0 bg-white dark:bg-dark-surface rounded-2xl border border-slate-100 dark:border-slate-800 overflow-hidden shadow-sm group cursor-pointer">
                        <div class="h-40 relative overflow-hidden bg-slate-100"><img :src="item.image" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"></div>
                        <div class="p-4">
                            <h4 class="font-bold text-sm text-professional dark:text-white truncate" x-text="item.title"></h4>
                            <p class="text-primary font-black text-sm mt-1">UGX <span x-text="item.price"></span></p>
                        </div>
                    </div>
                </template>
            </div>
        </div>

    </div>

    <div class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl border-t border-slate-200 dark:border-slate-800 p-4 pb-safe flex gap-3 transition-transform duration-300"
         :class="showMobileContact ? 'translate-y-0' : 'translate-y-full'">
        <a :href="`tel:${hostel.phones[0]}`" class="flex-1 btn-primary py-3 shadow-lg"><i class="fa-solid fa-phone"></i> Call</a>
        <a :href="`https://wa.me/${hostel.whatsapps[0]}`" target="_blank" class="w-14 bg-[#25D366]/10 text-[#25D366] rounded-xl flex items-center justify-center text-xl"><i class="fa-brands fa-whatsapp"></i></a>
    </div>

    <div x-show="galleryOpen" class="fixed inset-0 z-[100] bg-black flex flex-col" style="display: none;">
        <div class="p-4 flex justify-between items-center text-white">
            <span class="font-bold text-sm" x-text="`${activeImageIndex + 1} / ${allPhotos.length}`"></span>
            <button @click="galleryOpen = false" class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center hover:bg-white/40 transition-colors"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="flex-1 relative flex items-center justify-center overflow-hidden">
            <img :src="allPhotos[activeImageIndex]" class="max-w-full max-h-full object-contain">
            <button @click="activeImageIndex = (activeImageIndex - 1 + allPhotos.length) % allPhotos.length" class="absolute left-4 w-12 h-12 bg-black/50 text-white rounded-full flex items-center justify-center hover:bg-black/80"><i class="fa-solid fa-chevron-left"></i></button>
            <button @click="activeImageIndex = (activeImageIndex + 1) % allPhotos.length" class="absolute right-4 w-12 h-12 bg-black/50 text-white rounded-full flex items-center justify-center hover:bg-black/80"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>
</div>

<script>
function propertyDetails() {
    // In reality, this data comes from your NestJS controller rendering
    const dummyRoom = { type: 'Double', price: 1500000, pricingPeriod: 'Per Semester', floorLevel: 2, totalRooms: 20, availableRooms: 5, isSelfContained: true, hasBalcony: true, hasAC: false, cookingMethods: ['Electricity', 'Gas'], isFurnished: true, furniture: ['Beds', 'Reading Table', 'Closet'], photos: ['https://images.unsplash.com/photo-1522771731470-ea43374b422a?w=800'] };
    const dummyHostel = { name: 'Olympia Premium Hostel', locationName: 'Makerere', popularAreaName: 'Kikoni', distance: 500, locationType: 'University', isVerified: true, phones: ['0700000000'], whatsapps: ['0700000000'], gallery: ['https://images.unsplash.com/photo-1555854877-bab0e564b8d5?w=800', 'https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?w=800'], amenities: { security: true, freeInternet: true, readingRoom: true, gym: false }, roomsCount: 4 };
    const dummyManager = { firstName: 'Sarah', lastName: 'K.', role: 'hostel_manager', photo: '' };

    return {
        room: dummyRoom, hostel: dummyHostel, managerProfile: dummyManager,
        
        // Computed Image Array (Room Photos + Hostel Gallery)
        allPhotos: [...(dummyRoom.photos || []), ...(dummyHostel.gallery || [])],
        activeImageIndex: 0,
        galleryOpen: false,
        isSaved: false,
        showMobileContact: false,

        reviews: { avgRating: 4.8, total: 124, latest: { author: 'John D.', comment: 'Very clean and the manager is extremely helpful. Best hostel in Kikoni.' } },
        
        similarProperties: [
            { id: 1, title: 'Nana Hostel Single', price: '1,200,000', image: 'https://images.unsplash.com/photo-1522771731470-ea43374b422a?w=400' },
            { id: 2, title: 'Douglas Villa Double', price: '1,400,000', image: 'https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?w=400' }
        ],

        init() {
            window.addEventListener('scroll', () => { this.showMobileContact = window.scrollY > 300; });
        },

        updateActiveImage(e) {
            const container = e.target;
            const scrollPosition = container.scrollLeft;
            const imageWidth = container.offsetWidth;
            this.activeImageIndex = Math.round(scrollPosition / imageWidth);
        },

        openGallery(index) {
            this.activeImageIndex = index;
            this.galleryOpen = true;
        },

        toggleSave() {
            this.isSaved = !this.isSaved;
            // API call to save property would go here
        },

        generateRoomDescription() {
            let desc = `This is a spacious ${this.room.type} room located on Floor ${this.room.floorLevel}. `;
            desc += `It is a ${this.room.isSelfContained ? 'self-contained' : 'standard'} unit `;
            if (this.room.hasBalcony) desc += 'featuring a private balcony. ';
            else desc += '. ';
            
            if (this.room.isFurnished) desc += `The room comes fully furnished for your convenience. `;
            if (this.room.cookingMethods && this.room.cookingMethods.length) {
                desc += `Cooking is permitted using ${this.room.cookingMethods.join(' or ')}. `;
            }
            return desc;
        }
    }
}
</script>