<%- include('../layout') %>

<main class="flex-1">
  <!-- Header -->
  <div class="border-b border-slate-200 dark:border-slate-700 p-6">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Properties</h1>
        <p class="text-slate-600 dark:text-slate-400 mt-1">Manage your rental properties</p>
      </div>
      <button
        @click="activeTab = 'add'; resetForm()"
        class="bg-teal-600 hover:bg-teal-700 text-white px-6 py-2 rounded-lg font-medium transition"
      >
        + Add Property
      </button>
    </div>
  </div>

  <!-- Tabs -->
  <div class="border-b border-slate-200 dark:border-slate-700 px-6">
    <div class="flex space-x-8">
      <button
        @click="activeTab = 'overview'"
        :class="activeTab === 'overview' ? 'border-b-2 border-teal-600 text-teal-600' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-300'"
        class="py-4 font-medium transition"
      >
        Overview
      </button>
      <button
        @click="activeTab = 'listings'"
        :class="activeTab === 'listings' ? 'border-b-2 border-teal-600 text-teal-600' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-300'"
        class="py-4 font-medium transition"
      >
        Listings
      </button>
      <button
        @click="activeTab = 'verification'"
        :class="activeTab === 'verification' ? 'border-b-2 border-teal-600 text-teal-600' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-300'"
        class="py-4 font-medium transition"
      >
        Verification
      </button>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6" x-data="propertyDashboard()" @load="init()">
    <!-- Overview Tab -->
    <div x-show="activeTab === 'overview'" class="space-y-6">
      <!-- Statistics Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Total Properties</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2" x-text="stats.totalProperties"></p>
            </div>
            <div class="w-12 h-12 bg-teal-100 dark:bg-teal-900 rounded-lg flex items-center justify-center">
              <i class="fas fa-home text-teal-600 text-xl"></i>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Verified</p>
              <p class="text-3xl font-bold text-emerald-600 mt-2" x-text="stats.verifiedCount"></p>
            </div>
            <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900 rounded-lg flex items-center justify-center">
              <i class="fas fa-check-circle text-emerald-600 text-xl"></i>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Pending</p>
              <p class="text-3xl font-bold text-amber-600 mt-2" x-text="stats.pendingVerificationCount"></p>
            </div>
            <div class="w-12 h-12 bg-amber-100 dark:bg-amber-900 rounded-lg flex items-center justify-center">
              <i class="fas fa-clock text-amber-600 text-xl"></i>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Active</p>
              <p class="text-3xl font-bold text-blue-600 mt-2" x-text="stats.activeCount"></p>
            </div>
            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center">
              <i class="fas fa-eye text-blue-600 text-xl"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Property Types Distribution -->
      <div class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Property Types</h2>
        <div class="space-y-3">
          <template x-for="type in stats.propertyTypes" :key="type._id">
            <div class="flex items-center justify-between">
              <span class="text-slate-600 dark:text-slate-400 capitalize" x-text="type._id"></span>
              <div class="flex items-center gap-4">
                <div class="w-48 bg-slate-200 dark:bg-slate-700 rounded-full h-2">
                  <div
                    class="bg-teal-600 h-2 rounded-full"
                    :style="`width: ${(type.count / stats.totalProperties * 100)}%`"
                  ></div>
                </div>
                <span class="text-slate-900 dark:text-white font-medium w-8 text-right" x-text="type.count"></span>
              </div>
            </div>
          </template>
        </div>
      </div>
    </div>

    <!-- Listings Tab -->
    <div x-show="activeTab === 'listings'" class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <template x-for="property in properties" :key="property._id">
          <div class="bg-white dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-lg transition">
            <!-- Photo -->
            <div class="relative bg-slate-200 dark:bg-slate-700 h-48 flex items-center justify-center overflow-hidden">
              <img
                :src="property.coverPhoto || '/images/property-placeholder.png'"
                :alt="property.propertyName"
                class="w-full h-full object-cover"
              />
              <div class="absolute top-3 right-3">
                <span
                  :class="getVerificationBadgeClass(property.verificationStatus)"
                  class="px-3 py-1 rounded-full text-xs font-medium"
                  x-text="formatVerificationStatus(property.verificationStatus)"
                ></span>
              </div>
            </div>

            <!-- Details -->
            <div class="p-4">
              <h3 class="font-bold text-slate-900 dark:text-white" x-text="property.propertyName"></h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm mt-1">
                <i class="fas fa-home text-teal-600 mr-2"></i>
                <span x-text="formatHouseType(property.houseType)"></span> •
                <span x-text="property.unitCount + ' unit' + (property.unitCount !== 1 ? 's' : '')"></span>
              </p>

              <!-- Location -->
              <p class="text-slate-600 dark:text-slate-400 text-sm mt-2">
                <i class="fas fa-map-marker-alt text-red-600 mr-2"></i>
                <span x-text="property.nearestCity + ', ' + property.nearestTown"></span>
              </p>

              <!-- Rent -->
              <p class="text-teal-600 font-bold text-lg mt-3" x-text="'UGX ' + property.monthlyRent?.toLocaleString() || 'Not set'"></p>

              <!-- Actions -->
              <div class="flex gap-2 mt-4">
                <button
                  @click="editProperty(property)"
                  class="flex-1 px-3 py-2 bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-900 dark:text-white rounded-lg text-sm font-medium transition"
                >
                  <i class="fas fa-edit mr-2"></i>Edit
                </button>
                <button
                  @click="deleteProperty(property._id)"
                  class="flex-1 px-3 py-2 bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/30 text-red-600 rounded-lg text-sm font-medium transition"
                >
                  <i class="fas fa-trash mr-2"></i>Delete
                </button>
              </div>
            </div>
          </div>
        </template>
      </div>

      <div x-show="properties.length === 0" class="text-center py-12">
        <i class="fas fa-inbox text-slate-300 dark:text-slate-700 text-4xl mb-4"></i>
        <p class="text-slate-600 dark:text-slate-400">No properties yet. Add your first property to get started.</p>
      </div>
    </div>

    <!-- Verification Tab -->
    <div x-show="activeTab === 'verification'" class="space-y-6">
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-4 rounded-lg">
        <p class="text-blue-900 dark:text-blue-200">
          <i class="fas fa-info-circle mr-2"></i>
          Upload proof of ownership (property deed, lease agreement, or license) to get your properties verified and increase trust with tenants.
        </p>
      </div>

      <div class="space-y-4">
        <template x-for="property in properties.filter(p => p.verificationStatus !== 'verified')" :key="property._id">
          <div class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <h3 class="font-bold text-slate-900 dark:text-white" x-text="property.propertyName"></h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mt-1" x-text="property.nearestCity + ', ' + property.nearestTown"></p>

                <div class="mt-4 space-y-2">
                  <div class="flex items-center gap-2">
                    <span
                      :class="property.verificationStatus === 'pending' ? 'text-amber-600' : 'text-slate-400'"
                      class="text-xs font-medium"
                    >
                      <i :class="property.verificationStatus === 'pending' ? 'fas fa-clock' : 'fas fa-circle'" class="mr-2"></i>
                      <span x-text="property.verificationStatus === 'pending' ? 'Verification Pending' : 'Not Submitted'"></span>
                    </span>
                  </div>
                </div>
              </div>

              <div class="text-right">
                <template x-if="property.verificationStatus === 'unverified'">
                  <button
                    @click="showProofUpload(property._id)"
                    class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition"
                  >
                    Upload Proof
                  </button>
                </template>
                <template x-if="property.verificationStatus === 'pending'">
                  <span class="text-amber-600 text-sm font-medium">Under Review</span>
                </template>
              </div>
            </div>
          </div>
        </template>
      </div>
    </div>

    <!-- Add/Edit Modal -->
    <div
      x-show="showModal"
      @click="showModal = false"
      class="fixed inset-0 bg-black/50 z-40"
    ></div>

    <div x-show="showModal" class="fixed inset-0 z-50 flex items-center justify-center p-4">
      <div
        @click.stop
        class="bg-white dark:bg-slate-800 rounded-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto"
      >
        <!-- Progress Tracker -->
        <div class="border-b border-slate-200 dark:border-slate-700 p-6">
          <div class="flex justify-between mb-4">
            <template x-for="i in 3" :key="i">
              <div class="flex flex-col items-center">
                <div
                  :class="formStep >= i ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-400'"
                  class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm"
                  x-text="i"
                ></div>
                <p
                  class="text-xs mt-2 text-slate-600 dark:text-slate-400"
                  x-text="['Basics', 'Features', 'Location'][i-1]"
                ></p>
              </div>
            </template>
          </div>
          <div class="w-full bg-slate-200 dark:bg-slate-700 h-1 rounded-full">
            <div class="bg-teal-600 h-1 rounded-full transition-all" :style="`width: ${(formStep - 1) * 50 + 50}%`"></div>
          </div>
        </div>

        <!-- Form Content -->
        <div class="p-6 space-y-4">
          <!-- Step 1: Basics -->
          <template x-if="formStep === 1">
            <div class="space-y-4">
              <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Property Basics</h2>

              <div>
                <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Property Name</label>
                <input
                  type="text"
                  x-model="form.propertyName"
                  placeholder="e.g., Sky View Apartments"
                  class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-900 dark:text-white mb-3">House Type</label>
                <div class="grid grid-cols-3 gap-2">
                  <template x-for="type in rentalUtils.houseTypes" :key="type">
                    <button
                      @click="form.houseType = type"
                      :class="form.houseType === type ? 'bg-teal-600 text-white border-teal-600' : 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white border-slate-200 dark:border-slate-600'"
                      class="px-3 py-2 border rounded-lg font-medium text-sm transition"
                      x-text="formatHouseType(type)"
                    ></button>
                  </template>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-900 dark:text-white mb-3">Building Style</label>
                <div class="flex gap-2">
                  <button
                    @click="form.buildingStyle = 'flat_storey'"
                    :class="form.buildingStyle === 'flat_storey' ? 'bg-teal-600 text-white border-teal-600' : 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white border-slate-200 dark:border-slate-600'"
                    class="flex-1 px-3 py-2 border rounded-lg font-medium transition"
                  >
                    Flat/Storey
                  </button>
                  <button
                    @click="form.buildingStyle = 'single_level'"
                    :class="form.buildingStyle === 'single_level' ? 'bg-teal-600 text-white border-teal-600' : 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white border-slate-200 dark:border-slate-600'"
                    class="flex-1 px-3 py-2 border rounded-lg font-medium transition"
                  >
                    Single Level
                  </button>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Unit Count</label>
                  <input
                    type="number"
                    x-model.number="form.unitCount"
                    min="1"
                    class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Monthly Rent</label>
                  <input
                    type="number"
                    x-model.number="form.monthlyRent"
                    placeholder="0"
                    class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                  />
                </div>
              </div>
            </div>
          </template>

          <!-- Step 2: Features -->
          <template x-if="formStep === 2">
            <div class="space-y-6">
              <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Property Features</h2>

              <!-- Property Features -->
              <div>
                <label class="block text-sm font-bold text-slate-900 dark:text-white mb-3">Features</label>
                <div class="space-y-3">
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.isSelfContained" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Self Contained</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.isFenced" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Fenced</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.isCompoundPaved" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Compound Paved</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.hasAmpleParking" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Ample Parking</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.hasOutsideWashrooms" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Outside Washrooms</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.hasSecurity" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Security</span>
                  </label>
                  <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" x-model="form.hasWater" class="w-4 h-4 rounded border-slate-300" />
                    <span class="text-slate-700 dark:text-slate-300">Water Available</span>
                  </label>
                </div>
              </div>

              <!-- Furnishing -->
              <div>
                <label class="flex items-center gap-3 cursor-pointer mb-3">
                  <input type="checkbox" x-model="form.isFurnished" class="w-4 h-4 rounded border-slate-300" />
                  <span class="text-sm font-bold text-slate-900 dark:text-white">Furnished</span>
                </label>

                <template x-if="form.isFurnished">
                  <div class="space-y-2 p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
                    <label class="text-sm font-medium text-slate-900 dark:text-white block mb-2">Select Furniture Items</label>
                    <template x-for="furniture in rentalUtils.furnitureItems" :key="furniture">
                      <label class="flex items-center gap-3 cursor-pointer">
                        <input
                          type="checkbox"
                          :value="furniture"
                          @change="toggleFurniture(furniture)"
                          class="w-4 h-4 rounded border-slate-300"
                        />
                        <span class="text-slate-700 dark:text-slate-300 text-sm" x-text="furniture"></span>
                      </label>
                    </template>
                  </div>
                </template>
              </div>

              <!-- Billing -->
              <div>
                <label class="block text-sm font-bold text-slate-900 dark:text-white mb-3">Billing Responsibility</label>
                <div class="space-y-3">
                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-2">Water Bill Paid By</label>
                    <div class="flex gap-2">
                      <button
                        @click="form.waterBillPaidBy = 'tenant'"
                        :class="form.waterBillPaidBy === 'tenant' ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white'"
                        class="flex-1 py-2 rounded-lg text-sm font-medium transition"
                      >
                        Tenant
                      </button>
                      <button
                        @click="form.waterBillPaidBy = 'landlord'"
                        :class="form.waterBillPaidBy === 'landlord' ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white'"
                        class="flex-1 py-2 rounded-lg text-sm font-medium transition"
                      >
                        Landlord
                      </button>
                    </div>
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-2">Electricity Bill Paid By</label>
                    <div class="flex gap-2">
                      <button
                        @click="form.electricityBillPaidBy = 'tenant'"
                        :class="form.electricityBillPaidBy === 'tenant' ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white'"
                        class="flex-1 py-2 rounded-lg text-sm font-medium transition"
                      >
                        Tenant
                      </button>
                      <button
                        @click="form.electricityBillPaidBy = 'landlord'"
                        :class="form.electricityBillPaidBy === 'landlord' ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white'"
                        class="flex-1 py-2 rounded-lg text-sm font-medium transition"
                      >
                        Landlord
                      </button>
                    </div>
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-2">Security Fee Paid By</label>
                    <div class="flex gap-2">
                      <button
                        @click="form.securityFeePaidBy = 'tenant'"
                        :class="form.securityFeePaidBy === 'tenant' ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white'"
                        class="flex-1 py-2 rounded-lg text-sm font-medium transition"
                      >
                        Tenant
                      </button>
                      <button
                        @click="form.securityFeePaidBy = 'landlord'"
                        :class="form.securityFeePaidBy === 'landlord' ? 'bg-teal-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-white'"
                        class="flex-1 py-2 rounded-lg text-sm font-medium transition"
                      >
                        Landlord
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </template>

          <!-- Step 3: Location -->
          <template x-if="formStep === 3">
            <div class="space-y-4">
              <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6">Location & Proximity</h2>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Nearest Town</label>
                  <input
                    type="text"
                    x-model="form.nearestTown"
                    placeholder="e.g., Kampala"
                    class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Nearest City</label>
                  <input
                    type="text"
                    x-model="form.nearestCity"
                    placeholder="e.g., Kampala City"
                    class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Nearest Road</label>
                <input
                  type="text"
                  x-model="form.nearestRoad"
                  placeholder="e.g., Kampala-Jinja Highway"
                  class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-900 dark:text-white mb-3">Access Road Type</label>
                <div class="flex gap-2">
                  <button
                    @click="form.accessRoadType = 'tarmac'"
                    :class="form.accessRoadType === 'tarmac' ? 'bg-teal-600 text-white border-teal-600' : 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white border-slate-200 dark:border-slate-600'"
                    class="flex-1 px-3 py-2 border rounded-lg font-medium transition"
                  >
                    Tarmac
                  </button>
                  <button
                    @click="form.accessRoadType = 'murram_gravel'"
                    :class="form.accessRoadType === 'murram_gravel' ? 'bg-teal-600 text-white border-teal-600' : 'bg-white dark:bg-slate-700 text-slate-900 dark:text-white border-slate-200 dark:border-slate-600'"
                    class="flex-1 px-3 py-2 border rounded-lg font-medium transition"
                  >
                    Murram/Gravel
                  </button>
                </div>
              </div>

              <template x-if="form.accessRoadType === 'murram_gravel'">
                <div>
                  <label class="block text-sm font-medium text-slate-900 dark:text-white mb-2">Distance to Tarmac (km)</label>
                  <input
                    type="number"
                    x-model.number="form.distanceToTarmac"
                    placeholder="0"
                    class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500"
                  />
                </div>
              </template>

              <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
                <label class="block text-sm font-bold text-slate-900 dark:text-white mb-3">Proximity to Points of Interest</label>

                <div class="space-y-3">
                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Distance to Gym</label>
                    <input
                      type="text"
                      x-model="form.distanceToGym"
                      placeholder="e.g., 500m walk"
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Distance to Supermarket</label>
                    <input
                      type="text"
                      x-model="form.distanceToSupermarket"
                      placeholder="e.g., 1km drive"
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Distance to Groceries</label>
                    <input
                      type="text"
                      x-model="form.distanceToGroceries"
                      placeholder="e.g., 300m walk"
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Shopping Center Name</label>
                    <input
                      type="text"
                      x-model="form.shoppingCenterName"
                      placeholder="e.g., Garden City"
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>
                </div>
              </div>

              <div class="pt-4 border-t border-slate-200 dark:border-slate-700">
                <label class="block text-sm font-bold text-slate-900 dark:text-white mb-3">Contact Information</label>

                <div class="space-y-3">
                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Contact Person</label>
                    <input
                      type="text"
                      x-model="form.contactPerson"
                      placeholder="Full name"
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Telephone</label>
                    <input
                      type="text"
                      x-model="form.telephone"
                      placeholder="+256..."
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">WhatsApp</label>
                    <input
                      type="text"
                      x-model="form.whatsapp"
                      placeholder="+256..."
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>

                  <div>
                    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Email</label>
                    <input
                      type="email"
                      x-model="form.email"
                      placeholder="email@example.com"
                      class="w-full px-4 py-2 border border-slate-200 dark:border-slate-700 dark:bg-slate-700 dark:text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 text-sm"
                    />
                  </div>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Footer -->
        <div class="border-t border-slate-200 dark:border-slate-700 p-6 flex gap-3 justify-end">
          <button
            @click="showModal = false"
            class="px-6 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition"
          >
            Cancel
          </button>

          <template x-if="formStep > 1">
            <button
              @click="formStep--"
              class="px-6 py-2 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white font-medium hover:bg-slate-50 dark:hover:bg-slate-700 transition"
            >
              Back
            </button>
          </template>

          <template x-if="formStep < 3">
            <button
              @click="formStep++"
              class="px-6 py-2 bg-teal-600 hover:bg-teal-700 text-white rounded-lg font-medium transition"
            >
              Next
            </button>
          </template>

          <template x-if="formStep === 3">
            <button
              @click="saveProperty()"
              :disabled="loading"
              class="px-6 py-2 bg-teal-600 hover:bg-teal-700 text-white rounded-lg font-medium transition disabled:opacity-50"
            >
              <span x-show="!loading">Save Property</span>
              <span x-show="loading"><i class="fas fa-spinner fa-spin mr-2"></i>Saving...</span>
            </button>
          </template>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  function propertyDashboard() {
    return {
      activeTab: 'overview',
      showModal: false,
      formStep: 1,
      loading: false,
      properties: [],
      stats: {
        totalProperties: 0,
        verifiedCount: 0,
        pendingVerificationCount: 0,
        activeCount: 0,
        propertyTypes: [],
      },
      form: {
        propertyName: '',
        description: '',
        houseType: 'studio',
        buildingStyle: 'flat_storey',
        unitCount: 1,
        monthlyRent: 0,
        isSelfContained: false,
        isFenced: false,
        isCompoundPaved: false,
        hasAmpleParking: false,
        hasOutsideWashrooms: false,
        hasSecurity: false,
        hasWater: false,
        isFurnished: false,
        furnitureList: [],
        waterBillPaidBy: 'tenant',
        electricityBillPaidBy: 'tenant',
        securityFeePaidBy: 'landlord',
        nearestTown: '',
        nearestCity: '',
        nearestRoad: '',
        accessRoadType: 'tarmac',
        distanceToTarmac: 0,
        distanceToGym: '',
        distanceToSupermarket: '',
        distanceToGroceries: '',
        shoppingCenterName: '',
        contactPerson: '',
        telephone: '',
        whatsapp: '',
        email: '',
      },

      rentalUtils: {
        houseTypes: ['studio', '1-bedroom', '2-bedroom', '3-bedroom', '4-bedroom'],
        furnitureItems: ['Bed', 'Sofa', 'Fridge', 'Cooker', 'Dining Table', 'Chairs', 'Wardrobe', 'Desk'],
      },

      async init() {
        await this.loadProperties();
        await this.loadStats();
      },

      async loadProperties() {
        try {
          const response = await fetch('/api/rentals/my-properties');
          const data = await response.json();
          this.properties = data.rentals || [];
        } catch (error) {
          console.error('Error loading properties:', error);
          showToast('Error loading properties', 'error');
        }
      },

      async loadStats() {
        try {
          const response = await fetch('/api/rentals/dashboard/stats');
          const data = await response.json();
          this.stats = data;
        } catch (error) {
          console.error('Error loading stats:', error);
        }
      },

      resetForm() {
        this.formStep = 1;
        this.form = {
          propertyName: '',
          description: '',
          houseType: 'studio',
          buildingStyle: 'flat_storey',
          unitCount: 1,
          monthlyRent: 0,
          isSelfContained: false,
          isFenced: false,
          isCompoundPaved: false,
          hasAmpleParking: false,
          hasOutsideWashrooms: false,
          hasSecurity: false,
          hasWater: false,
          isFurnished: false,
          furnitureList: [],
          waterBillPaidBy: 'tenant',
          electricityBillPaidBy: 'tenant',
          securityFeePaidBy: 'landlord',
          nearestTown: '',
          nearestCity: '',
          nearestRoad: '',
          accessRoadType: 'tarmac',
          distanceToTarmac: 0,
          distanceToGym: '',
          distanceToSupermarket: '',
          distanceToGroceries: '',
          shoppingCenterName: '',
          contactPerson: '',
          telephone: '',
          whatsapp: '',
          email: '',
        };
      },

      toggleFurniture(item) {
        if (this.form.furnitureList.includes(item)) {
          this.form.furnitureList = this.form.furnitureList.filter(f => f !== item);
        } else {
          this.form.furnitureList.push(item);
        }
      },

      formatHouseType(type) {
        return type.charAt(0).toUpperCase() + type.slice(1);
      },

      formatVerificationStatus(status) {
        const statuses = {
          unverified: 'Unverified',
          pending: 'Pending',
          verified: 'Verified',
          rejected: 'Rejected',
        };
        return statuses[status] || 'Unknown';
      },

      getVerificationBadgeClass(status) {
        const classes = {
          unverified: 'bg-slate-100 text-slate-800 dark:bg-slate-700 dark:text-slate-200',
          pending: 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200',
          verified: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200',
          rejected: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
        };
        return classes[status] || classes.unverified;
      },

      editProperty(property) {
        this.form = { ...property };
        this.showModal = true;
      },

      async saveProperty() {
        this.loading = true;
        try {
          const method = this.form._id ? 'PUT' : 'POST';
          const endpoint = this.form._id ? `/api/rentals/${this.form._id}` : '/api/rentals';

          const response = await fetch(endpoint, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(this.form),
          });

          if (!response.ok) {
            throw new Error('Error saving property');
          }

          showToast('Property saved successfully!', 'success');
          this.showModal = false;
          await this.loadProperties();
          await this.loadStats();
        } catch (error) {
          console.error('Error saving property:', error);
          showToast('Error saving property', 'error');
        } finally {
          this.loading = false;
        }
      },

      async deleteProperty(propertyId) {
        if (!confirm('Are you sure you want to delete this property?')) return;

        try {
          const response = await fetch(`/api/rentals/${propertyId}`, { method: 'DELETE' });
          if (!response.ok) throw new Error('Error deleting property');

          showToast('Property deleted successfully', 'success');
          await this.loadProperties();
          await this.loadStats();
        } catch (error) {
          console.error('Error deleting property:', error);
          showToast('Error deleting property', 'error');
        }
      },

      async showProofUpload(propertyId) {
        const proofUrl = prompt('Enter the URL of your proof document (deed/license):');
        if (!proofUrl) return;

        try {
          const response = await fetch(`/api/rentals/${propertyId}/upload-proof`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ proofUrl }),
          });

          if (!response.ok) throw new Error('Error uploading proof');

          showToast('Proof uploaded. Your property is under review.', 'success');
          await this.loadProperties();
        } catch (error) {
          console.error('Error uploading proof:', error);
          showToast('Error uploading proof', 'error');
        }
      },
    };
  }
</script>
