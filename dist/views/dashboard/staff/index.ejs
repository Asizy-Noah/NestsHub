<%- include('../../partials/staff-sidebar') %>

<div class="staff-layout">
  <!-- Top Navigation -->
  <header class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Dashboard</h1>
      <div class="flex items-center space-x-4">
        <button onclick="document.documentElement.classList.toggle('dark')" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700">
          <i class="fas fa-moon dark:hidden"></i>
          <i class="fas fa-sun hidden dark:inline"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-6 py-8">
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Total Hostels Card -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Hostels</p>
            <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2"><%= stats.totalHostels || 0 %></p>
          </div>
          <div class="p-3 bg-blue-100 dark:bg-blue-900 rounded-lg">
            <i class="fas fa-hotel text-blue-600 dark:text-blue-300 text-2xl"></i>
          </div>
        </div>
      </div>

      <!-- Total Hotels Card -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Hotels</p>
            <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2"><%= stats.totalHotels || 0 %></p>
          </div>
          <div class="p-3 bg-blue-100 dark:bg-blue-900 rounded-lg">
            <i class="fas fa-building text-blue-600 dark:text-blue-300 text-2xl"></i>
          </div>
        </div>
      </div>

      <!-- Total Rentals Card -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Rentals</p>
            <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2"><%= stats.totalRentals || 0 %></p>
          </div>
          <div class="p-3 bg-blue-100 dark:bg-blue-900 rounded-lg">
            <i class="fas fa-house text-blue-600 dark:text-blue-300 text-2xl"></i>
          </div>
        </div>
      </div>

      <!-- My Blogs Card -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">My Blogs</p>
            <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2"><%= stats.myBlogs || 0 %></p>
          </div>
          <div class="p-3 bg-blue-100 dark:bg-blue-900 rounded-lg">
            <i class="fas fa-blog text-blue-600 dark:text-blue-300 text-2xl"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 mb-8">
      <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Quick Actions</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/blogs/create" class="p-4 border-2 border-slate-200 dark:border-slate-700 rounded-lg hover:border-blue-500 transition text-center">
          <i class="fas fa-plus text-blue-600 text-2xl mb-2"></i>
          <p class="text-sm font-medium text-slate-900 dark:text-white">New Blog</p>
        </a>
        <a href="/dashboard/staff/hostels" class="p-4 border-2 border-slate-200 dark:border-slate-700 rounded-lg hover:border-blue-500 transition text-center">
          <i class="fas fa-list text-blue-600 text-2xl mb-2"></i>
          <p class="text-sm font-medium text-slate-900 dark:text-white">View Hostels</p>
        </a>
        <a href="/dashboard/staff/hotels" class="p-4 border-2 border-slate-200 dark:border-slate-700 rounded-lg hover:border-blue-500 transition text-center">
          <i class="fas fa-list text-blue-600 text-2xl mb-2"></i>
          <p class="text-sm font-medium text-slate-900 dark:text-white">View Hotels</p>
        </a>
        <a href="/blogs" class="p-4 border-2 border-slate-200 dark:border-slate-700 rounded-lg hover:border-blue-500 transition text-center">
          <i class="fas fa-pen text-blue-600 text-2xl mb-2"></i>
          <p class="text-sm font-medium text-slate-900 dark:text-white">My Blogs</p>
        </a>
      </div>
    </div>

    <!-- Information Banner -->
    <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-lg p-6 mb-8">
      <div class="flex items-start space-x-4">
        <div class="flex-shrink-0">
          <i class="fas fa-info-circle text-blue-600 dark:text-blue-300 text-2xl mt-1"></i>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-100">Staff Responsibilities</h3>
          <p class="text-blue-800 dark:text-blue-200 mt-1">As a staff member, you have read-only access to view all properties and can manage blog content. You cannot edit or delete property listings.</p>
        </div>
      </div>
    </div>

    <!-- Recent Blogs -->
    <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white">My Recent Blogs</h2>
        <a href="/blogs/create" class="text-blue-600 hover:text-blue-700 text-sm font-medium">+ New Blog</a>
      </div>
      <div class="space-y-4">
        <% if (recentBlogs && recentBlogs.length > 0) { %>
          <% recentBlogs.forEach(blog => { %>
            <div class="flex items-center justify-between p-4 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition">
              <div class="flex-1">
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white"><%= blog.title %></h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1"><%= blog.status %> • <%= new Date(blog.createdAt).toLocaleDateString() %></p>
              </div>
              <div class="flex items-center space-x-2">
                <a href="/blogs/edit/<%= blog._id %>" class="p-2 text-blue-600 hover:bg-blue-50 dark:hover:bg-slate-600 rounded">
                  <i class="fas fa-edit"></i>
                </a>
                <button onclick="deleteBlog('<%= blog._id %>')" class="p-2 text-red-600 hover:bg-red-50 dark:hover:bg-slate-600 rounded">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <p class="text-slate-500 dark:text-slate-400 text-center py-8">No blogs yet. Create your first blog!</p>
        <% } %>
      </div>
    </div>
  </main>
</div>

<!-- Include Toast Notifications -->
<%- include('../../partials/toast-notification') %>

<script>
function deleteBlog(blogId) {
  if (confirm('Are you sure you want to delete this blog?')) {
    fetch(`/blogs/${blogId}`, {
      method: 'DELETE',
      headers: {
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      }
    }).then(res => {
      if (res.ok) {
        location.reload();
      }
    }).catch(err => console.error(err));
  }
}
</script>
