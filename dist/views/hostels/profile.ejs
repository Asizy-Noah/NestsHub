<div class="max-w-4xl mx-auto px-4 sm:px-6 py-8" x-data="managerProfile(<%= typeof account !== 'undefined' ? account : '{}' %>)" x-cloak>
    
    <div class="card space-y-8 mb-8">
        <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-6">
            <div>
                <h1 class="text-3xl font-black text-professional dark:text-white">Manager Profile</h1>
                <p class="text-slate-500 text-sm">Update your personal identity and global contact info.</p>
            </div>
            <div class="w-12 h-12 bg-primary/10 text-primary rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-user-tie"></i></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="flex flex-col items-center gap-4">
                <div class="w-40 h-40 rounded-full border-4 border-slate-100 dark:border-slate-800 overflow-hidden shadow-inner bg-slate-50 relative flex items-center justify-center">
                    <template x-if="profile.photo"><img :src="profile.photo" class="w-full h-full object-cover"></template>
                    <template x-if="!profile.photo"><i class="fa-solid fa-user text-5xl text-slate-300"></i></template>
                </div>
                <label class="btn-outline text-xs py-2 px-4 cursor-pointer">
                    Change Photo <input type="file" accept="image/*" class="hidden" @change="uploadPhoto">
                </label>
            </div>

            <div class="md:col-span-2 space-y-5">
                <div class="grid grid-cols-2 gap-4">
                    <div class="input-group"><label>First Name</label><input type="text" x-model="profile.firstName" class="input-field font-bold"></div>
                    <div class="input-group"><label>Last Name</label><input type="text" x-model="profile.lastName" class="input-field font-bold"></div>
                </div>
                <div class="input-group"><label>Primary Login Email</label><input type="email" x-model="profile.email" class="input-field bg-slate-100 dark:bg-slate-800 text-slate-500" disabled></div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-6 border-t border-slate-100 dark:border-slate-800">
            <div class="space-y-3">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Personal Phones</label>
                <template x-for="(phone, index) in profile.phones" :key="index">
                    <div class="flex gap-2"><input type="tel" x-model="profile.phones[index]" class="input-field py-2"><button @click="profile.phones.splice(index,1)" class="w-10 text-red-500 hover:bg-red-50 rounded-xl"><i class="fa-solid fa-trash"></i></button></div>
                </template>
                <button @click="profile.phones.push('')" class="text-xs font-bold text-primary"><i class="fa-solid fa-plus"></i> Add Phone</button>
            </div>
            
            <div class="space-y-3">
                <label class="text-xs font-bold text-emerald-500 uppercase tracking-wider block">Personal WhatsApp</label>
                <template x-for="(wa, index) in profile.whatsapps" :key="index">
                    <div class="flex gap-2"><input type="tel" x-model="profile.whatsapps[index]" class="input-field py-2 border-emerald-200"><button @click="profile.whatsapps.splice(index,1)" class="w-10 text-red-500 hover:bg-red-50 rounded-xl"><i class="fa-solid fa-trash"></i></button></div>
                </template>
                <button @click="profile.whatsapps.push('')" class="text-xs font-bold text-emerald-600"><i class="fa-solid fa-plus"></i> Add WhatsApp</button>
            </div>
        </div>

        <div class="pt-4 flex justify-between items-center border-t border-slate-100 dark:border-slate-800 pt-6">
            <button @click="saveProfile" class="btn-primary w-full md:w-auto px-10 shadow-xl" :disabled="saving">
                <span x-show="!saving">Save Identity Settings</span>
                <span x-show="saving"><i class="fa-solid fa-spinner fa-spin"></i> Updating...</span>
            </button>
        </div>
    </div>

    <div class="card space-y-6 border-red-100 dark:border-red-900/30 bg-red-50/30 dark:bg-red-900/10">
        <h3 class="text-xl font-bold flex items-center gap-2 border-b border-red-100 dark:border-red-900/30 pb-3 text-red-500">
            <i class="fa-solid fa-shield-halved"></i> Danger Zone
        </h3>
        
        <div class="flex flex-col sm:flex-row gap-4">
            <button @click="showPasswordForm = !showPasswordForm; showDeleteForm = false" class="btn-outline border-slate-300 text-slate-700 bg-white">
                <i class="fa-solid fa-key mr-2"></i> Change Password
            </button>
            
            <button @click="showDeleteForm = !showDeleteForm; showPasswordForm = false" class="btn-outline border-red-300 text-red-500 bg-white hover:bg-red-50">
                <i class="fa-solid fa-triangle-exclamation mr-2"></i> Delete Account
            </button>
        </div>

        <div x-show="showPasswordForm" x-collapse class="pt-4 border-t border-red-100 dark:border-red-900/30">
            <form @submit.prevent="updatePassword" class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-white dark:bg-slate-900 p-6 rounded-2xl shadow-sm">
                <div class="input-group md:col-span-2">
                    <label class="text-slate-500">Current Password</label>
                    <input type="password" x-model="passwords.currentPassword" class="input-field" required>
                </div>
                <div class="input-group">
                    <label class="text-slate-500">New Password</label>
                    <input type="password" x-model="passwords.newPassword" class="input-field" required minlength="6">
                </div>
                <div class="input-group">
                    <label class="text-slate-500">Confirm New Password</label>
                    <input type="password" x-model="passwords.confirmPassword" class="input-field" required minlength="6">
                </div>
                <div class="md:col-span-2 pt-2">
                    <button type="submit" class="btn-primary bg-slate-800 hover:bg-black" :disabled="savingPass">
                        <span x-show="!savingPass">Update Password</span>
                        <span x-show="savingPass"><i class="fa-solid fa-spinner fa-spin mr-2"></i> Verifying...</span>
                    </button>
                </div>
            </form>
        </div>

        <div x-show="showDeleteForm" x-collapse class="pt-4 border-t border-red-100 dark:border-red-900/30">
            <div class="bg-red-100 dark:bg-red-900/40 p-6 rounded-2xl border border-red-200 dark:border-red-800 space-y-4">
                <h4 class="text-red-600 dark:text-red-400 font-bold text-lg"><i class="fa-solid fa-skull"></i> Permanently Delete Account</h4>
                <p class="text-sm text-red-800/70 dark:text-red-200/70 font-medium">This action cannot be undone. This will permanently delete your account, your profile, and remove all your data from our servers.</p>
                
                <div class="input-group mt-4">
                    <label class="text-red-700">Please type <span class="font-black italic text-red-600 bg-red-200 px-2 py-0.5 rounded">delete my account</span> to confirm.</label>
                    <input type="text" x-model="deleteConfirmText" class="input-field border-red-300 focus:border-red-500 focus:ring-red-500/30 bg-white" placeholder="Type here...">
                </div>
                
                <button @click="deleteAccount" 
                        class="px-6 py-3 rounded-xl font-bold transition-all shadow-md mt-4 w-full flex items-center justify-center gap-2 text-white"
                        :class="deleteConfirmText === 'delete my account' ? 'bg-red-600 hover:bg-red-700 hover:shadow-lg' : 'bg-red-300 cursor-not-allowed'"
                        :disabled="deleteConfirmText !== 'delete my account' || savingDelete">
                    <span x-show="!savingDelete">Permanently Delete Account</span>
                    <span x-show="savingDelete"><i class="fa-solid fa-spinner fa-spin"></i> Deleting...</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function managerProfile(accountData) {
    return {
        saving: false, savingPass: false, savingDelete: false,
        showPasswordForm: false, showDeleteForm: false,
        deleteConfirmText: '',
        
        profile: {
            firstName: accountData.firstName || '', lastName: accountData.lastName || '', email: accountData.email || '',
            photo: accountData.photo || '', phones: accountData.phones || [''], whatsapps: accountData.whatsapps || ['']
        },
        passwords: { currentPassword: '', newPassword: '', confirmPassword: '' },
        
        init() {
            if(!this.profile.phones.length) this.profile.phones = [''];
            if(!this.profile.whatsapps.length) this.profile.whatsapps = [''];
        },
        uploadPhoto(e) {
            const file = e.target.files[0];
            if(file) {
                const reader = new FileReader();
                reader.onload = ev => this.profile.photo = ev.target.result;
                reader.readAsDataURL(file);
            }
        },
        
        getHeaders() {
            return { 'Content-Type': 'application/json', 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` };
        },

        async saveProfile() {
            this.profile.phones = this.profile.phones.filter(p => p && p.trim());
            this.profile.whatsapps = this.profile.whatsapps.filter(w => w && w.trim());
            if(!this.profile.phones.length) this.profile.phones.push('');
            
            this.saving = true;
            try {
                // IMPORTANT: Extract only necessary fields to prevent DTO rejection
                const payload = {
                    firstName: this.profile.firstName,
                    lastName: this.profile.lastName,
                    photo: this.profile.photo,
                    phones: this.profile.phones,
                    whatsapps: this.profile.whatsapps
                };

                const res = await fetch('/accounts/update', {
                    method: 'PATCH',
                    headers: this.getHeaders(),
                    body: JSON.stringify(payload)
                });
                
                const data = await res.json();
                if(!res.ok) throw new Error(data.message || "Failed to update");
                alert("Identity saved successfully.");
            } catch (e) { 
                alert(e.message || "Failed to save profile."); 
            } finally { 
                this.saving = false; 
            }
        },

        async updatePassword() {
            if(this.passwords.newPassword !== this.passwords.confirmPassword) return alert("New passwords do not match!");
            this.savingPass = true;
            try {
                const res = await fetch('/accounts/change-password', {
                    method: 'PATCH',
                    headers: this.getHeaders(),
                    body: JSON.stringify({ currentPassword: this.passwords.currentPassword, newPassword: this.passwords.newPassword })
                });
                const data = await res.json();
                if(!res.ok) throw new Error(data.message || 'Verification failed');
                
                alert("Password updated securely.");
                this.passwords = { currentPassword: '', newPassword: '', confirmPassword: '' };
                this.showPasswordForm = false;
            } catch (e) { alert(e.message); } finally { this.savingPass = false; }
        },

        async deleteAccount() {
            if(this.deleteConfirmText !== 'delete my account') return;
            this.savingDelete = true;
            try {
                const res = await fetch('/accounts/delete', {
                    method: 'DELETE',
                    headers: this.getHeaders()
                });
                if(!res.ok) throw new Error();
                
                alert("Account deleted permanently.");
                localStorage.removeItem('accessToken');
                window.location.href = '/auth/login';
            } catch (e) {
                alert("Failed to delete account.");
                this.savingDelete = false;
            }
        }
    }
}
</script>