<div class="w-full max-w-md mx-auto" x-data="loginHandler()">
    <div class="text-center mb-10">
        <h1 class="text-4xl font-extrabold text-professional dark:text-white mb-3">Welcome Back</h1>
        <p class="text-slate-500">Sign in to your NestHub dashboard</p>
    </div>

    <div class="card">
        <form @submit.prevent="submitLogin" class="space-y-6">
            
            <div class="input-group">
                <label>Email Address</label>
                <input type="email" x-model="email" placeholder="you@example.com" required class="input-field">
                <i class="fa-regular fa-envelope input-icon"></i>
            </div>

            <div class="input-group">
                <div class="flex justify-between items-center w-full">
                    <label>Password</label>
                    <a href="/auth/forgot-password" class="text-sm text-accent hover:text-amber-500 transition-colors font-semibold">Forgot password?</a>
                </div>
                <input type="password" x-model="password" placeholder="••••••••" required class="input-field">
                <i class="fa-solid fa-lock input-icon"></i>
            </div>

            <button type="submit" class="btn-primary w-full mt-2" :disabled="loading">
                <span x-show="!loading">Secure Sign In <i class="fa-solid fa-arrow-right-to-bracket"></i></span>
                <span x-show="loading"><i class="fa-solid fa-circle-notch fa-spin"></i> Authenticating...</span>
            </button>
        </form>
    </div>

    <p class="text-center mt-8 text-slate-500 font-medium">New to NestHub? <a href="/auth/register" class="text-primary hover:text-emerald-500 transition-colors">Create an account</a></p>
</div>

<script>
function loginHandler() {
    return {
        email: '',
        password: '',
        loading: false,
        async submitLogin() {
            this.loading = true;
            try {
                const response = await fetch('/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: this.email, password: this.password }),
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || 'Invalid credentials');
                }

                // Store the token for protected dashboard access
                localStorage.setItem('accessToken', result.accessToken);

                // Use the backend-provided redirect path
                if (result.redirect) {
                    window.location.href = result.redirect;
                } else {
                    window.location.href = '/dashboard';
                }

            } catch (err) {
                alert(err.message);
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>