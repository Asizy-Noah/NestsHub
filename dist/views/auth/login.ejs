
<div class="max-w-md mx-auto px-4 py-12" x-data="loginForm()" x-cloak>
    <div class="card">
        <h1 class="text-3xl font-bold text-center mb-8">Sign In</h1>

        <!-- Error Messages -->
        <div x-show="error" class="alert-error mb-6">
            <span x-text="error"></span>
            <button @click="error = ''" class="float-right text-xl">&times;</button>
        </div>

        <form @submit.prevent="submitForm()" class="space-y-6">
            <div>
                <label class="block text-sm font-medium mb-2">Email Address</label>
                <input 
                    type="email" 
                    x-model="formData.email" 
                    class="input-field"
                    placeholder="you@example.com"
                    required
                >
            </div>

            <div>
                <label class="block text-sm font-medium mb-2">Password</label>
                <input 
                    type="password" 
                    x-model="formData.password" 
                    class="input-field"
                    placeholder="••••••••"
                    required
                >
            </div>

            <button 
                type="submit" 
                class="btn-primary w-full"
                :disabled="loading"
                x-text="loading ? 'Signing in...' : 'Sign In'"
            ></button>
        </form>

        <div class="mt-6 space-y-3 text-center">
            <a href="/auth/forgot-password" class="block text-blue-600 hover:underline text-sm">
                Forgot your password?
            </a>
            <p class="text-gray-600 dark-mode:text-gray-400">
                Don't have an account? <a href="/auth/register" class="text-blue-600 hover:underline">Sign up</a>
            </p>
        </div>
    </div>
</div>

<script>
function loginForm() {
    return {
        loading: false,
        error: '',
        formData: {
            email: '',
            password: '',
        },

        async submitForm() {
            this.loading = true;
            this.error = '';

            try {
                const response = await fetch('/auth/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(this.formData),
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Login failed');
                }

                // Store token
                localStorage.setItem('accessToken', data.accessToken);
                localStorage.setItem('user', JSON.stringify(data.user));

                // Redirect to dashboard
                window.location.href = '/accounts/dashboard';
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>

