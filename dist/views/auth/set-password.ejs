<div class="w-full max-w-md mx-auto" x-data="passwordForm()">
    
    <div class="text-center mb-10">
        <div class="w-16 h-16 bg-primary/10 text-primary rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm">
            <i class="fa-solid fa-shield-halved text-3xl"></i>
        </div>
        <h1 class="text-3xl font-extrabold text-professional dark:text-white mb-2">Secure Your Account</h1>
        <p class="text-slate-500">Create a strong password to continue.</p>
    </div>

    <div class="card relative overflow-hidden">
        <div x-show="error" x-transition 
             class="p-4 mb-6 bg-red-500/10 text-red-500 border border-red-500/20 rounded-xl text-sm font-semibold flex items-center gap-2" x-cloak>
            <i class="fa-solid fa-circle-exclamation"></i>
            <span x-text="error"></span>
        </div>

        <form @submit.prevent="submitForm" class="space-y-6">
            <div class="input-group">
                <label>New Password</label>
                <input type="password" x-model="password" @input="validate" required class="input-field" placeholder="••••••••">
                <i class="fa-solid fa-key input-icon"></i>
            </div>

            <div class="bg-slate-50 dark:bg-slate-900 rounded-xl p-4 border border-slate-200 dark:border-slate-700">
                <p class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">Password Requirements</p>
                <div class="space-y-2 text-sm font-medium">
                    <div class="flex items-center gap-2" :class="checks.length ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid" :class="checks.length ? 'fa-circle-check' : 'fa-circle-dot'"></i> Minimum 8 characters
                    </div>
                    <div class="flex items-center gap-2" :class="checks.upper ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid" :class="checks.upper ? 'fa-circle-check' : 'fa-circle-dot'"></i> Uppercase letter
                    </div>
                    <div class="flex items-center gap-2" :class="checks.number ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid" :class="checks.number ? 'fa-circle-check' : 'fa-circle-dot'"></i> At least one number
                    </div>
                    <div class="flex items-center gap-2" :class="checks.special ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid" :class="checks.special ? 'fa-circle-check' : 'fa-circle-dot'"></i> Special character
                    </div>
                </div>
            </div>

            <div class="input-group">
                <label>Confirm Password</label>
                <input type="password" x-model="confirm" required class="input-field" placeholder="••••••••">
                <i class="fa-solid fa-lock input-icon"></i>
                <div x-show="confirm && password !== confirm" class="text-red-500 text-xs font-semibold mt-1 flex items-center gap-1" x-cloak>
                    <i class="fa-solid fa-circle-xmark"></i> Passwords do not match
                </div>
            </div>

            <button type="submit" class="btn-primary w-full mt-2" :disabled="loading || !isValid">
                <span x-show="!loading">Save Password & Access Dashboard</span>
                <span x-show="loading" class="flex items-center justify-center gap-2">
                    <i class="fa-solid fa-circle-notch fa-spin"></i> Processing...
                </span>
            </button>
        </form>
    </div>
</div>

<script>
function passwordForm() {
    return {
        password: '',
        confirm: '',
        loading: false,
        error: '',
        checks: { length: false, upper: false, number: false, special: false },
        
        validate() {
            const p = this.password;
            this.checks.length = p.length >= 8;
            this.checks.upper = /[A-Z]/.test(p);
            this.checks.number = /[0-9]/.test(p);
            this.checks.special = /[@$!%*?&]/.test(p);
        },

        get isValid() {
            // Check all rules + confirm matches + password is not empty
            return this.checks.length && 
                   this.checks.upper && 
                   this.checks.number && 
                   this.checks.special && 
                   this.password === this.confirm && 
                   this.password.length > 0;
        },

        async submitForm() {
            if (!this.isValid) return;

            this.loading = true;
            this.error = '';

            // 1. Get accountId from the URL ?accountId=XXXX
            const urlParams = new URLSearchParams(window.location.search);
            const accountId = urlParams.get('accountId');

            if (!accountId) {
                this.error = "No account ID found. Please use the original link from your email.";
                this.loading = false;
                return;
            }

            try {
                // 2. Make the POST call to NestJS
                const response = await fetch(`/auth/set-password?accountId=${accountId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        password: this.password,
                        confirmPassword: this.confirm 
                    }),
                });

                const result = await response.json();

                if (!response.ok) {
                    // Capture NestJS validation errors (message is often an array or string)
                    throw new Error(result.message || 'Failed to save password');
                }

                // 3. SUCCESS: Redirect to login
                window.location.href = '/auth/login?status=password_set';

            } catch (err) {
                console.error("Submission error:", err);
                this.error = Array.isArray(err.message) ? err.message[0] : err.message;
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>