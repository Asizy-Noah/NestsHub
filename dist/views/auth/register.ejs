<div class="max-w-lg mx-auto px-4 py-12" x-data="{ 
    step: 1, 
    accountType: '', 
    showToast: false,
    toastMessage: '',
    toastType: 'success',
    submitForm() {
        // Simulate API Call
        this.showToast = true;
        this.toastMessage = 'Registration successful! Please check your email for the verification link.';
        this.toastType = 'success';
        setTimeout(() => { this.showToast = false }, 5000);
    }
}">
    
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary text-white mb-4 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>
        </div>
        <h1 class="text-3xl font-bold text-professional dark:text-white">Create an Account</h1>
        <p class="text-slate-500 mt-2">Join NestHub to manage your properties</p>
    </div>

    <div class="card relative overflow-hidden">
        <div class="flex items-center justify-between mb-8 relative">
            <div class="absolute left-0 top-1/2 transform -translate-y-1/2 w-full h-1 bg-slate-200 dark:bg-slate-700 z-0"></div>
            <div class="absolute left-0 top-1/2 transform -translate-y-1/2 h-1 bg-primary transition-all duration-300 z-0" :style="'width: ' + ((step - 1) * 50) + '%'"></div>
            
            <template x-for="i in 3">
                <div class="relative z-10 flex flex-col items-center">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm transition-colors duration-300"
                         :class="step >= i ? 'bg-primary text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400'">
                        <span x-text="i"></span>
                    </div>
                </div>
            </template>
        </div>

        <form @submit.prevent="submitForm">
            <div x-show="step === 1" x-transition.opacity>
                <h2 class="text-xl font-semibold mb-4 text-professional dark:text-white">Select Account Type</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="cursor-pointer border border-slate-200 dark:border-slate-700 rounded-xl p-4 hover:border-primary transition-colors"
                           :class="accountType === 'tenant' ? 'border-primary bg-primary/5 dark:bg-primary/10' : ''">
                        <input type="radio" name="type" value="tenant" x-model="accountType" class="hidden">
                        <div class="font-bold text-professional dark:text-white">Tenant / Guest</div>
                        <div class="text-sm text-slate-500 mt-1">Looking for a place to stay</div>
                    </label>
                    <label class="cursor-pointer border border-slate-200 dark:border-slate-700 rounded-xl p-4 hover:border-primary transition-colors"
                           :class="accountType === 'manager' ? 'border-primary bg-primary/5 dark:bg-primary/10' : ''">
                        <input type="radio" name="type" value="manager" x-model="accountType" class="hidden">
                        <div class="font-bold text-professional dark:text-white">Property Manager</div>
                        <div class="text-sm text-slate-500 mt-1">Managing properties/hostels</div>
                    </label>
                </div>
                <button type="button" @click="if(accountType) step = 2" class="btn-primary w-full mt-6" :disabled="!accountType" :class="!accountType ? 'opacity-50 cursor-not-allowed' : ''">Continue</button>
            </div>

            <div x-show="step === 2" x-transition.opacity x-cloak>
                <h2 class="text-xl font-semibold mb-4 text-professional dark:text-white">Personal Details</h2>
                
                <div class="space-y-4">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
                        </div>
                        <input type="text" placeholder="Full Name" required class="input-field">
                    </div>

                    <div x-show="accountType === 'manager'" x-collapse class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008z" /></svg>
                        </div>
                        <input type="text" placeholder="Company / Property Name" :required="accountType === 'manager'" class="input-field">
                    </div>
                </div>

                <div class="flex gap-4 mt-6">
                    <button type="button" @click="step = 1" class="btn-secondary w-1/3">Back</button>
                    <button type="button" @click="step = 3" class="btn-primary w-2/3">Continue</button>
                </div>
            </div>

            <div x-show="step === 3" x-transition.opacity x-cloak>
                <h2 class="text-xl font-semibold mb-4 text-professional dark:text-white">Account Email</h2>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                    </div>
                    <input type="email" placeholder="Email Address" required class="input-field">
                </div>
                
                <div class="flex gap-4 mt-6">
                    <button type="button" @click="step = 2" class="btn-secondary w-1/3">Back</button>
                    <button type="submit" class="btn-primary w-2/3">Send Verification Link</button>
                </div>
            </div>
        </form>
    </div>

    <div x-show="showToast" x-transition.opacity class="fixed bottom-4 right-4 z-50 rounded-lg p-4 shadow-xl text-white flex items-center space-x-3"
         :class="toastType === 'success' ? 'bg-primary' : 'bg-red-500'" x-cloak>
        <svg x-show="toastType === 'success'" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span x-text="toastMessage" class="font-medium"></span>
    </div>

    <p class="text-center mt-6 text-slate-500">Already have an account? <a href="/auth/login" class="text-primary hover:underline font-semibold">Sign in</a></p>
</div>