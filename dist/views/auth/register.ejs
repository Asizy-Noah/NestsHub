<div class="w-full max-w-2xl" x-data="registrationForm()">
    
    <div class="mb-12 relative">
        <div class="absolute top-1/2 left-0 w-full h-1 bg-slate-200 dark:bg-slate-800 -translate-y-1/2 rounded-full z-0"></div>
        <div class="absolute top-1/2 left-0 h-1 bg-accent -translate-y-1/2 rounded-full z-0 transition-all duration-500" :style="'width: ' + ((step - 1) * 50) + '%'"></div>
        
        <div class="flex justify-between relative z-10">
            <template x-for="(label, index) in ['Account Type', 'Details', 'Complete']">
                <div class="flex flex-col items-center gap-2">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm shadow-md transition-colors duration-500"
                         :class="step > index ? 'bg-accent text-white' : (step === index + 1 ? 'bg-accent text-white ring-4 ring-accent/30' : 'bg-light-surface dark:bg-dark-surface text-slate-400 border-2 border-slate-200 dark:border-slate-700')">
                        <span x-text="index + 1"></span>
                    </div>
                    <span class="text-xs font-semibold uppercase tracking-wider" :class="step >= index + 1 ? 'text-professional dark:text-white' : 'text-slate-400'" x-text="label"></span>
                </div>
            </template>
        </div>
    </div>

    <div class="card relative overflow-hidden">
        
        <div x-show="toast.show" x-transition class="absolute top-0 left-0 w-full p-4 text-center font-semibold text-sm z-20" :class="toast.type === 'success' ? 'bg-primary/10 text-primary border-b border-primary/20' : 'bg-red-500/10 text-red-500 border-b border-red-500/20'">
            <i class="fa-solid mr-2" :class="toast.type === 'success' ? 'fa-circle-check' : 'fa-circle-exclamation'"></i>
            <span x-text="toast.message"></span>
        </div>

        <form @submit.prevent="submitForm" class="mt-4">
            
            <div x-show="step === 1" x-transition.opacity.duration.300ms>
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-bold text-professional dark:text-white mb-2">Join NestHub</h2>
                    <p class="text-slate-500">Select how you will be using the platform.</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <template x-for="role in roles" :key="role.id">
                        <label class="cursor-pointer border-2 rounded-2xl p-5 transition-all duration-200 flex flex-col items-center text-center gap-3"
                               :class="formData.accountType === role.id ? 'border-primary bg-primary/5 dark:bg-primary/10 shadow-md scale-[1.02]' : 'border-slate-200 dark:border-slate-700 hover:border-primary/50'">
                            <input type="radio" name="accountType" :value="role.id" x-model="formData.accountType" class="hidden">
                            <div class="w-12 h-12 rounded-full flex items-center justify-center" :class="formData.accountType === role.id ? 'bg-primary text-white' : 'bg-slate-100 dark:bg-slate-800 text-slate-500'">
                                <i class="fa-solid text-xl" :class="role.icon"></i>
                            </div>
                            <div>
                                <div class="font-bold text-professional dark:text-white" x-text="role.title"></div>
                                <div class="text-xs text-slate-500 mt-1" x-text="role.desc"></div>
                            </div>
                        </label>
                    </template>
                </div>
                <button type="button" @click="if(formData.accountType) step = 2" class="btn-primary w-full mt-8" :disabled="!formData.accountType" :class="!formData.accountType ? 'opacity-50 cursor-not-allowed' : ''">
                    Continue <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>

            <div x-show="step === 2" x-transition.opacity.duration.300ms x-cloak>
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold text-professional dark:text-white mb-2">Personal Details</h2>
                    <p class="text-slate-500">Fill in your profile information.</p>
                </div>

                <div class="space-y-5">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div class="input-group">
                            <label>First Name</label>
                            <input type="text" x-model="formData.firstName" required class="input-field" placeholder="John">
                            <i class="fa-regular fa-user input-icon"></i>
                        </div>
                        <div class="input-group">
                            <label>Last Name</label>
                            <input type="text" x-model="formData.lastName" required class="input-field" placeholder="Doe">
                            <i class="fa-regular fa-user input-icon"></i>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Other Names (Optional)</label>
                        <input type="text" x-model="formData.otherNames" class="input-field" placeholder="Middle Name">
                        <i class="fa-regular fa-id-badge input-icon"></i>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div class="input-group">
                            <label>Email Address</label>
                            <input type="email" x-model="formData.email" required class="input-field" placeholder="john@example.com">
                            <i class="fa-regular fa-envelope input-icon"></i>
                        </div>
                        <div class="input-group">
                            <label>Phone Number</label>
                            <input type="tel" x-model="formData.phone" required class="input-field" placeholder="+1 234 567 890">
                            <i class="fa-solid fa-phone input-icon"></i>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div class="input-group">
                            <label>Nationality</label>
                            <input type="text" x-model="formData.nationality" required class="input-field" placeholder="e.g. American">
                            <i class="fa-solid fa-globe input-icon"></i>
                        </div>
                        <div class="input-group">
                            <label>Passport / ID Number</label>
                            <input type="text" x-model="formData.idNumber" required class="input-field" placeholder="Document ID">
                            <i class="fa-solid fa-passport input-icon"></i>
                        </div>
                    </div>

                    <div x-show="['hostel_manager', 'hotel_manager'].includes(formData.accountType)" x-collapse>
                        <div class="p-5 mt-4 bg-emerald-50 dark:bg-emerald-900/10 border border-emerald-100 dark:border-emerald-800/30 rounded-xl space-y-5">
                            <h3 class="text-sm font-bold text-primary uppercase tracking-wide">Manager Details</h3>
                            
                            <div class="input-group" x-show="formData.accountType === 'hostel_manager'" x-cloak>
                                <label>Name of Hostel</label>
                                <input type="text" 
                                    x-model="formData.hostelName" 
                                    :required="formData.accountType === 'hostel_manager'" 
                                    class="input-field" 
                                    placeholder="Sunrise Hostels">
                                <i class="fa-solid fa-bed input-icon"></i>
                            </div>

                            <div class="input-group" x-show="formData.accountType === 'hotel_manager'" x-cloak>
                                <label>Name of Hotel</label>
                                <input type="text" 
                                    x-model="formData.hotelName" 
                                    :required="formData.accountType === 'hotel_manager'" 
                                    class="input-field" 
                                    placeholder="Grand Plaza Hotel">
                                <i class="fa-solid fa-hotel input-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div x-show="formData.accountType === 'admin'" x-collapse>
                        <div class="p-5 mt-4 bg-slate-100 dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
                            <div class="input-group">
                                <label>Internal Department / Access Code</label>
                                <input type="text" x-model="formData.adminCode" :required="formData.accountType === 'admin'" class="input-field" placeholder="System Code">
                                <i class="fa-solid fa-shield-halved input-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex gap-4 mt-8">
                    <button type="button" @click="step = 1" class="btn-outline w-1/3">Back</button>
                    <button type="submit" class="btn-primary w-2/3" :disabled="loading">
                        <span x-show="!loading">Submit Registration</span>
                        <span x-show="loading"><i class="fa-solid fa-circle-notch fa-spin"></i> Processing...</span>
                    </button>
                </div>
            </div>

            <div x-show="step === 3" x-transition.opacity.duration.300ms x-cloak class="text-center py-8">
                <div class="w-20 h-20 bg-primary/10 text-primary rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fa-solid fa-envelope-circle-check text-4xl"></i>
                </div>
                <h2 class="text-2xl font-bold text-professional dark:text-white mb-4">Check Your Email</h2>
                <p class="text-slate-500 mb-8 max-w-sm mx-auto">We've sent a secure validation token to <strong class="text-professional dark:text-white" x-text="formData.email"></strong>. Please click the link to activate your account and set your password.</p>
                <a href="/auth/login" class="btn-outline w-full justify-center">Return to Login</a>
            </div>

        </form>
    </div>
    <p class="text-center mt-8 text-slate-500 font-medium">Already have an account? <a href="/auth/login" class="text-primary hover:text-emerald-500 transition-colors">Sign In</a></p>
</div>

<script>
function registrationForm() {
    return {
        step: 1,
        loading: false,
        toast: { show: false, message: '', type: 'success' },
        roles: [
            { id: 'property_manager', title: 'Property Owner/Broker', desc: 'List and manage properties', icon: 'fa-house-user' },
            { id: 'hostel_manager', title: 'Hostel Manager', desc: 'Manage hostel branches', icon: 'fa-bed' },
            { id: 'hotel_manager', title: 'Hotel Manager', desc: 'Manage hotels & hostels', icon: 'fa-hotel' },
            { id: 'admin', title: 'System Admin', desc: 'Internal staff access', icon: 'fa-user-tie' }
        ],
        formData: {
            accountType: '', firstName: '', lastName: '', otherNames: '', email: '', phone: '', nationality: '', idNumber: '', hostelName: '', hotelName: '', adminCode: ''
        },
        
        async submitForm() {
    this.loading = true;
    this.toast.show = false;

    // 1. Destructure to separate accountType from the rest of the data
    const { accountType, ...otherDetails } = this.formData;

    // 2. Construct the final payload for the backend
    const payload = {
        ...otherDetails,
        role: accountType // Map the frontend selection to the backend "role" field
    };

    try {
        const response = await fetch('/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok) {
            throw new Error(result.message || 'Registration failed');
        }

        this.toast = { show: true, message: 'Registration successful! Check your email.', type: 'success' };
        this.step = 3;
        
    } catch (err) {
        // Handle validation errors or connection issues
        this.toast = { 
            show: true, 
            message: Array.isArray(err.message) ? err.message[0] : err.message, 
            type: 'error' 
        };
        window.scrollTo({ top: 0, behavior: 'smooth' });
    } finally {
        this.loading = false;
    }
}
    }
}
</script>