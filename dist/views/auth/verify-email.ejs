<div class="w-full max-w-md mx-auto" x-data="verifyEmailForm('<%= typeof token !== 'undefined' ? token : '' %>')" x-init="init()">
    
    <div class="card text-center relative overflow-hidden">
        <div x-show="success && !loading" x-transition.opacity x-cloak>
            <div class="w-20 h-20 bg-primary/10 text-primary rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
                <i class="fa-solid fa-check-double text-4xl"></i>
            </div>
            <h1 class="text-3xl font-extrabold text-professional dark:text-white mb-4">Email Verified!</h1>
            <p class="text-slate-500 mb-8">Your email has been successfully verified. We are redirecting you to secure your account.</p>
            <div class="flex items-center justify-center gap-2 text-primary font-bold">
                <i class="fa-solid fa-circle-notch fa-spin"></i> Redirecting...
            </div>
        </div>

        <div x-show="error && !loading" x-transition.opacity x-cloak>
            <div class="w-20 h-20 bg-red-500/10 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
                <i class="fa-solid fa-triangle-exclamation text-4xl"></i>
            </div>
            <h1 class="text-3xl font-extrabold text-professional dark:text-white mb-4">Verification Failed</h1>
            <p class="text-slate-500 mb-8" x-text="error"></p>
            <a href="/auth/register" class="btn-outline w-full justify-center">Back to Registration</a>
        </div>

        <div x-show="loading" class="py-8">
            <div class="w-16 h-16 text-primary mx-auto mb-6 animate-spin">
                <i class="fa-solid fa-circle-notch text-5xl"></i>
            </div>
            <h2 class="text-xl font-bold text-professional dark:text-white">Verifying...</h2>
        </div>
    </div>
</div>

<script>
function verifyEmailForm(token) {
    return {
        loading: true,
        success: false,
        error: '',
        async init() {
            if (!token) {
                this.error = 'No verification token provided.';
                this.loading = false;
                return;
            }
            try {
                const response = await fetch('/auth/verify-email', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token }),
                });
                
                const data = await response.json();
                
                if (!response.ok) throw new Error(data.message || 'Verification failed');
                
                this.success = true;

                // RECTIFICATION: Pass the accountId in the query string during redirect
                setTimeout(() => { 
                    if (data.accountId) {
                        window.location.href = `/auth/set-password?accountId=${data.accountId}`; 
                    } else {
                        this.error = "Verified, but failed to retrieve account ID.";
                        this.success = false;
                    }
                }, 2000);

            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        }
    };
}
</script>