<%- include('../partials/layout-top') %>

<div class="max-w-6xl mx-auto px-4 py-12">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-4">Blog</h1>
    <p class="text-lg text-slate-600 dark:text-slate-300">Insights on real estate, properties, and more</p>
  </div>

  <!-- Search Bar -->
  <div class="mb-8">
    <form method="GET" action="/blogs/search" class="flex gap-2">
      <input 
        type="text" 
        name="q" 
        placeholder="Search blogs..." 
        class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white"
      >
      <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">
        Search
      </button>
    </form>
  </div>

  <!-- Blogs Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
    <% if (blogs && blogs.length > 0) { %>
      <% blogs.forEach(blog => { %>
        <article class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition">
          <!-- Cover Image -->
          <% if (blog.coverImage) { %>
            <div class="h-48 bg-gradient-to-br from-indigo-400 to-indigo-600 overflow-hidden">
              <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" class="w-full h-full object-cover">
            </div>
          <% } else { %>
            <div class="h-48 bg-gradient-to-br from-indigo-400 to-indigo-600"></div>
          <% } %>

          <!-- Content -->
          <div class="p-6">
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2">
              <a href="/blogs/<%= blog.slug %>" class="hover:text-indigo-600 dark:hover:text-indigo-400">
                <%= blog.title %>
              </a>
            </h2>
            
            <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">
              By <%= blog.authorName %> • <%= new Date(blog.createdAt).toLocaleDateString() %>
            </p>

            <p class="text-slate-700 dark:text-slate-300 line-clamp-3 mb-4">
              <%= blog.content.substring(0, 150) %>...
            </p>

            <!-- Tags -->
            <% if (blog.tags && blog.tags.length > 0) { %>
              <div class="flex flex-wrap gap-2 mb-4">
                <% blog.tags.slice(0, 3).forEach(tag => { %>
                  <span class="px-2 py-1 bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 rounded text-xs">
                    #<%= tag %>
                  </span>
                <% }); %>
              </div>
            <% } %>

            <!-- Footer -->
            <div class="flex items-center justify-between pt-4 border-t border-slate-200 dark:border-slate-700">
              <div class="flex items-center space-x-4 text-sm text-slate-500 dark:text-slate-400">
                <span><i class="fas fa-eye"></i> <%= blog.views || 0 %></span>
              </div>
              <a href="/blogs/<%= blog.slug %>" class="text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300 font-medium text-sm">
                Read More →
              </a>
            </div>
          </div>
        </article>
      <% }); %>
    <% } else { %>
      <div class="col-span-full text-center py-12">
        <i class="fas fa-book text-6xl text-slate-300 dark:text-slate-600 mb-4"></i>
        <p class="text-xl text-slate-600 dark:text-slate-400">No blogs found</p>
      </div>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (pagination && pagination.pages > 1) { %>
    <div class="flex items-center justify-center gap-2 mb-8">
      <% for (let i = 1; i <= pagination.pages; i++) { %>
        <% if (i === pagination.page) { %>
          <span class="px-4 py-2 bg-indigo-600 text-white rounded-lg">
            <%= i %>
          </span>
        <% } else { %>
          <a href="?page=<%= i %>" class="px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700">
            <%= i %>
          </a>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../partials/layout-bottom') %>
