<%- include('../partials/layout-top') %>

<div x-data="createBlogForm()" class="max-w-4xl mx-auto px-4 py-12">
  <!-- Header -->
  <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-8">Create New Blog</h1>

  <!-- Form -->
  <form @submit.prevent="submitForm()" class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8 space-y-6">
    <!-- Title -->
    <div>
      <label class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
        Blog Title *
      </label>
      <input 
        type="text" 
        x-model="form.title"
        placeholder="Enter blog title"
        class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
        required
      >
    </div>

    <!-- Cover Image -->
    <div>
      <label class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
        Cover Image
      </label>
      <div class="border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-lg p-6 text-center">
        <input 
          type="file" 
          @change="handleImageUpload"
          accept="image/*"
          class="hidden"
          id="coverImage"
        >
        <label for="coverImage" class="cursor-pointer">
          <% if (false) { %>
            <img :src="imagePreview" alt="Preview" class="max-h-48 mx-auto mb-4">
          <% } else { %>
            <i class="fas fa-cloud-upload-alt text-4xl text-slate-400 mb-2"></i>
            <p class="text-slate-600 dark:text-slate-400">Click to upload cover image</p>
            <p class="text-sm text-slate-500 dark:text-slate-500">PNG, JPG up to 5MB</p>
          <% } %>
        </label>
      </div>
    </div>

    <!-- Content -->
    <div>
      <label class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
        Blog Content *
      </label>
      <textarea 
        x-model="form.content"
        placeholder="Write your blog content here..."
        rows="12"
        class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
        required
      ></textarea>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">
        Character count: <span x-text="form.content.length"></span>
      </p>
    </div>

    <!-- Tags -->
    <div>
      <label class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
        Tags (comma separated)
      </label>
      <input 
        type="text" 
        x-model="form.tags"
        placeholder="real estate, property, investment"
        class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
      >
    </div>

    <!-- Status -->
    <div>
      <label class="block text-sm font-semibold text-slate-900 dark:text-white mb-2">
        Status
      </label>
      <div class="flex gap-4">
        <label class="flex items-center">
          <input 
            type="radio" 
            x-model="form.status"
            value="draft"
            class="w-4 h-4"
          >
          <span class="ml-2 text-slate-700 dark:text-slate-300">Draft</span>
        </label>
        <label class="flex items-center">
          <input 
            type="radio" 
            x-model="form.status"
            value="published"
            class="w-4 h-4"
          >
          <span class="ml-2 text-slate-700 dark:text-slate-300">Published</span>
        </label>
      </div>
    </div>

    <!-- Buttons -->
    <div class="flex gap-4 pt-6 border-t border-slate-200 dark:border-slate-700">
      <button 
        type="submit"
        :disabled="loading"
        class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed transition font-medium"
      >
        <span x-show="!loading">Create Blog</span>
        <span x-show="loading"><i class="fas fa-spinner fa-spin"></i> Creating...</span>
      </button>
      <a href="/blogs" class="px-6 py-2 border border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition font-medium">
        Cancel
      </a>
    </div>

    <!-- Error Message -->
    <div x-show="error" class="p-4 bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-lg">
      <p class="text-red-700 dark:text-red-200" x-text="error"></p>
    </div>
  </form>
</div>

<script>
function createBlogForm() {
  return {
    form: {
      title: '',
      content: '',
      coverImage: '',
      tags: '',
      status: 'draft',
    },
    loading: false,
    error: '',

    handleImageUpload(event) {
      const file = event.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (e) => {
          this.form.coverImage = e.target.result;
        };
        reader.readAsDataURL(file);
      }
    },

    async submitForm() {
      this.loading = true;
      this.error = '';

      try {
        const response = await fetch('/blogs', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${localStorage.getItem('token')}`
          },
          body: JSON.stringify({
            ...this.form,
            tags: this.form.tags.split(',').map(t => t.trim()).filter(Boolean)
          })
        });

        if (!response.ok) {
          throw new Error('Failed to create blog');
        }

        const data = await response.json();
        showToast('Blog created successfully!', 'success');
        window.location.href = `/blogs/${data.slug}`;
      } catch (err) {
        this.error = err.message;
        showToast(err.message, 'error');
      } finally {
        this.loading = false;
      }
    }
  };
}
</script>

<%- include('../partials/layout-bottom') %>
