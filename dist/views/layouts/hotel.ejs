<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= typeof title !== 'undefined' ? title + ' | NestHub' : 'NestHub Hotel Dashboard' %></title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#10B981', // Emerald
                        professional: '#1E293B', // Slate Blue
                        accent: '#F59E0B', // Amber
                        'dark-bg': '#0B1120',
                        'dark-surface': '#0F172A',
                    },
                    boxShadow: { 'glass': '0 10px 40px -10px rgba(0,0,0,0.08)' }
                }
            }
        }
    </script>

    <style type="text/tailwindcss">
        @layer components {
            .btn-primary { @apply px-6 py-3 bg-primary text-white rounded-xl hover:bg-emerald-600 active:scale-[0.98] transition-all duration-200 shadow-md flex items-center justify-center gap-2 font-bold disabled:opacity-70 disabled:cursor-not-allowed; }
            .btn-outline { @apply px-6 py-3 border-2 border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 rounded-xl hover:border-primary hover:text-primary transition-all duration-200 font-bold disabled:opacity-70 disabled:cursor-not-allowed; }
            .card { @apply bg-white dark:bg-dark-surface rounded-3xl shadow-glass p-8 border border-slate-200 dark:border-slate-800; }
            .input-group { @apply relative flex flex-col gap-1.5; }
            .input-group label { @apply text-xs font-bold text-slate-500 uppercase tracking-wider; }
            .input-field { @apply w-full px-4 py-3 bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary text-slate-800 dark:text-slate-200 transition-all duration-200; }
            .input-group .input-icon { @apply absolute left-4 top-[34px] text-slate-400 text-lg; }
            .input-group .input-icon ~ .input-field { @apply pl-12; }
        }
        [x-cloak] { display: none !important; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .dark ::-webkit-scrollbar-thumb { background: #334155; }
    </style>
</head>
<body x-data="dashboardLayout()" x-init="initTheme()" :class="isDark ? 'dark bg-dark-bg text-slate-200' : 'bg-slate-50 text-slate-800'" class="antialiased overflow-hidden font-sans" x-cloak>

    <div class="flex h-screen w-full">
        <div x-show="sidebarOpen" x-transition.opacity @click="sidebarOpen = false" class="fixed inset-0 z-40 bg-slate-900/60 backdrop-blur-sm lg:hidden"></div>

        <aside class="fixed inset-y-0 left-0 z-50 w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 transform transition-transform duration-300 ease-in-out lg:translate-x-0 lg:static lg:flex-shrink-0 flex flex-col"
               :class="sidebarOpen ? 'translate-x-0 shadow-2xl' : '-translate-x-full'">
            
            <div class="h-20 flex items-center justify-between px-6 border-b border-slate-100 dark:border-slate-800/50">
                <a href="/" class="flex items-center gap-3 group">
                    <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center text-white shadow-lg group-hover:scale-105 transition-transform"><i class="fa-solid fa-hotel text-xl"></i></div>
                    <span class="text-2xl font-black text-professional dark:text-white tracking-tight">Nest<span class="text-primary">Hub</span></span>
                </a>
                <button @click="sidebarOpen = false" class="lg:hidden text-slate-400 hover:text-red-500"><i class="fa-solid fa-xmark text-2xl"></i></button>
            </div>

            <div class="flex-1 overflow-y-auto p-4 space-y-1">
                <a href="/dashboard/hotel" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-bold text-primary bg-primary/10 transition-colors"><i class="fa-solid fa-chart-pie w-5 text-center"></i> Dashboard</a>
                <a href="/dashboard/hotel/reviews" class="flex items-center justify-between px-4 py-3.5 rounded-xl font-semibold text-slate-500 hover:text-professional dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    <div class="flex items-center gap-3"><i class="fa-solid fa-star w-5 text-center"></i> Reviews</div>
                </a>
                <a href="#" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-slate-500 hover:text-professional dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"><i class="fa-solid fa-bell-concierge w-5 text-center"></i> Bookings</a>
                <div class="pt-4 mt-4 border-t border-slate-100 dark:border-slate-800/50">
                    <p class="px-4 text-xs font-extrabold text-slate-400 uppercase tracking-wider mb-2">Settings</p>
                    <a href="/dashboard/hotel/profile" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-semibold text-slate-500 hover:text-professional dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"><i class="fa-solid fa-user-gear w-5 text-center"></i> My Profile</a>
                </div>
            </div>

            <div class="p-4 border-t border-slate-100 dark:border-slate-800/50">
                <div class="flex items-center gap-3 px-2 py-2">
                    <div class="w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-bold shadow-md">
                        <%= (typeof manager !== 'undefined' && manager && manager.firstName) ? manager.firstName.charAt(0) : 'M' %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-professional dark:text-white truncate"><%= (typeof manager !== 'undefined' && manager && manager.firstName) ? (manager.firstName + ' ' + (manager.lastName || '')) : 'Hotel Manager' %></p>
                        <p class="text-xs text-slate-400 truncate capitalize"><%= typeof manager !== 'undefined' ? manager.role.replace('_', ' ') : 'Account' %></p>
                    </div>
                    <button @click="logout" class="text-slate-400 hover:text-red-500 transition-colors"><i class="fa-solid fa-right-from-bracket"></i></button>
                </div>
            </div>
        </aside>

        <div class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden relative">
            <header class="h-20 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 flex items-center justify-between px-4 sm:px-6 lg:px-8 z-30">
                <div class="flex items-center gap-4">
                    <button @click="sidebarOpen = true" class="lg:hidden w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 flex items-center justify-center hover:bg-primary hover:text-white transition-colors"><i class="fa-solid fa-bars-staggered"></i></button>
                    <div class="hidden sm:flex items-center bg-slate-100 dark:bg-slate-800 rounded-xl px-4 py-2.5 w-64 ring-1 ring-transparent focus-within:ring-primary/30 focus-within:bg-white dark:focus-within:bg-slate-900 transition-all">
                        <i class="fa-solid fa-magnifying-glass text-slate-400 mr-3"></i>
                        <input type="text" placeholder="Search rooms..." class="bg-transparent border-none outline-none w-full text-sm font-semibold text-slate-700 dark:text-slate-200 placeholder-slate-400">
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <button class="w-10 h-10 rounded-xl flex items-center justify-center text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors relative">
                        <i class="fa-regular fa-bell text-lg"></i>
                        <span class="absolute top-2 right-2.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white dark:border-slate-900"></span>
                    </button>
                    <button @click="toggleTheme" class="w-10 h-10 rounded-xl flex items-center justify-center text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <i class="fa-solid text-lg" :class="isDark ? 'fa-sun text-amber-400' : 'fa-moon text-indigo-600'"></i>
                    </button>
                </div>
            </header>

            <main class="flex-1 overflow-y-auto overflow-x-hidden relative">
                <%- body %> 
            </main>
        </div>
    </div>

    <script>
        function dashboardLayout() {
            return {
                sidebarOpen: false,
                isDark: false,
                initTheme() {
                    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                        this.isDark = true;
                    } else { this.isDark = false; }
                },
                toggleTheme() {
                    this.isDark = !this.isDark;
                    localStorage.setItem('theme', this.isDark ? 'dark' : 'light');
                },
                logout() {
                    if (confirm('Are you sure you want to log out?')) {
                        localStorage.removeItem('accessToken');
                        window.location.href = '/auth/login'; 
                    }
                }
            }
        }
    </script>
</body>
</html>