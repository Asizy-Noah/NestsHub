<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Real Estate Management' %></title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        // Your Custom Palette
                        primary: '#10B981', // Emerald Green (Growth)
                        professional: '#1E293B', // Slate Blue (Professional)
                        accent: '#F59E0B', // Amber (Call to Action)
                        
                        // Light Mode Specs
                        'light-bg': '#F8FAFC', // Slate-50
                        'light-surface': '#FFFFFF', // White
                        'light-text': '#0F172A', // Slate-900
                        
                        // Dark Mode Specs
                        'dark-bg': '#020617', // Slate-950
                        'dark-surface': '#0F172A', // Slate-900
                        'dark-text': '#F1F5F9', // Slate-100
                    }
                }
            }
        }
    </script>

    <script type="text/tailwindcss">
        @layer components {
            /* Emerald Primary Button */
            .btn-primary {
                @apply px-6 py-2.5 bg-primary text-white rounded-lg hover:bg-emerald-600 transition-all duration-200 shadow-md inline-block text-center font-semibold;
            }
            /* Amber Accent Button for Bookings/Actions */
            .btn-accent {
                @apply px-6 py-2.5 bg-accent text-white rounded-lg hover:bg-amber-600 transition-all duration-200 shadow-md inline-block text-center font-semibold;
            }
            /* Professional Sidebar/Secondary Button */
            .btn-secondary {
                @apply px-6 py-2.5 bg-professional text-white rounded-lg hover:bg-slate-700 transition-all duration-200 inline-block text-center font-semibold;
            }
            /* Surface-based Card */
            .card {
                @apply bg-light-surface dark:bg-dark-surface text-light-text dark:text-dark-text rounded-xl shadow-lg p-8 border border-slate-200 dark:border-slate-800 hover:shadow-xl transition-all duration-300;
            }
        }
        @layer base {
            [x-cloak] { display: none !important; }
            body { @apply antialiased transition-colors duration-200; }
        }
    </script>
</head>
<body 
    x-data="{ darkMode: localStorage.getItem('darkMode') === 'true' }" 
    :class="darkMode ? 'dark bg-dark-bg text-dark-text' : 'bg-light-bg text-light-text'" 
    x-cloak
>
    <header class="bg-light-surface dark:bg-dark-surface border-b border-slate-200 dark:border-slate-800 sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
            <a href="/" class="font-bold text-xl flex items-center space-x-2">
                <span class="p-1.5 bg-primary text-white rounded-lg">RE</span>
                <span class="text-professional dark:text-dark-text">NestHub</span>
            </a>
            <div class="flex items-center space-x-4">
                <button @click="darkMode = !darkMode; localStorage.setItem('darkMode', darkMode)" 
                        class="p-2 bg-slate-100 dark:bg-slate-800 rounded-full text-slate-600 dark:text-slate-400">
                    <span x-show="!darkMode">🌙</span>
                    <span x-show="darkMode">☀️</span>
                </button>
            </div>
        </nav>
    </header>

    <main class="min-h-[calc(100vh-160px)]">
        <%- body %> 
    </main>

    <footer class="bg-light-surface dark:bg-dark-surface border-t border-slate-200 dark:border-slate-800 py-8 text-center text-sm text-slate-500">
        <p>&copy; 2026 Real Estate Management.</p>
    </footer>
</body>
</html>