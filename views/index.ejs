<div x-data="publicFeed()" class="min-h-screen relative w-full">

    <div class="sticky top-16 z-30 bg-slate-50 dark:bg-dark-bg pb-2 pt-2 transition-all shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <h2 class="text-sm font-black text-professional dark:text-white uppercase tracking-wider mb-3">What are you looking for?</h2>
            
            <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-1">
                <template x-for="tab in categories" :key="tab.id">
                    <button @click="activeCategory = tab.id; resetSearch()" 
                            class="flex items-center gap-2 px-5 py-2.5 rounded-full font-bold whitespace-nowrap transition-all border-2"
                            :class="activeCategory === tab.id ? 'border-primary bg-primary/10 text-primary shadow-sm' : 'border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-500 hover:border-slate-300 dark:hover:border-slate-600'">
                        <i class="fa-solid" :class="tab.icon"></i>
                        <span x-text="tab.label"></span>
                    </button>
                </template>
            </div>

            <div class="flex gap-2 mt-4">
                <button class="flex items-center gap-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 rounded-xl font-bold text-sm text-slate-600 dark:text-slate-300 shadow-sm hover:border-primary transition-colors flex-shrink-0">
                    <i class="fa-solid fa-location-dot text-primary"></i>
                    <span class="hidden sm:inline">Location</span>
                </button>
                
                <button @click="openSearchMode()" class="flex-1 flex items-center justify-between bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-4 py-3 rounded-xl font-bold text-sm text-slate-400 shadow-sm hover:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-left">
                    <div class="flex items-center gap-3">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <span x-text="`Search for ${activeCategory}...`"></span>
                    </div>
                    <div class="w-6 h-6 rounded bg-primary text-white flex items-center justify-center text-[10px]"><i class="fa-solid fa-arrow-right"></i></div>
                </button>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        
        <div class="flex justify-between items-end mb-6">
            <h3 class="text-lg sm:text-xl font-black text-professional dark:text-white relative inline-block">
                <span class="relative z-10">You May Like</span>
                <span class="absolute bottom-1 left-0 w-full h-2 bg-primary/20 z-0 rounded-full"></span>
            </h3>
            
            <div class="flex bg-slate-200 dark:bg-slate-800 p-1 rounded-lg">
                <button @click="viewMode = 'grid'" class="w-8 h-8 rounded flex items-center justify-center transition-colors" :class="viewMode === 'grid' ? 'bg-white dark:bg-slate-700 text-primary shadow-sm' : 'text-slate-400 hover:text-slate-600'"><i class="fa-solid fa-grip"></i></button>
                <button @click="viewMode = 'list'" class="w-8 h-8 rounded flex items-center justify-center transition-colors" :class="viewMode === 'list' ? 'bg-white dark:bg-slate-700 text-primary shadow-sm' : 'text-slate-400 hover:text-slate-600'"><i class="fa-solid fa-list"></i></button>
            </div>
        </div>

        <div x-show="viewMode === 'grid'" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 sm:gap-4">
            <template x-for="item in getFeedItems()" :key="item.id">
                <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-lg hover:border-primary/50 transition-all group cursor-pointer flex flex-col h-full relative">
                    <div class="relative w-full pt-[85%] bg-slate-100 dark:bg-slate-800 overflow-hidden">
                        <img :src="item.image" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold text-white shadow-sm" x-show="item.badge" x-text="item.badge"></div>
                        <button @click.stop="toggleSave(item.id)" class="absolute top-2 right-2 w-8 h-8 rounded-full bg-white/90 dark:bg-slate-900/90 flex items-center justify-center shadow-md hover:scale-110 transition-transform">
                            <i class="fa-solid fa-heart text-sm" :class="isSaved(item.id) ? 'text-red-500' : 'text-slate-300'"></i>
                        </button>
                    </div>
                    <div class="p-3 flex flex-col flex-1">
                        <h4 class="font-bold text-sm text-professional dark:text-white line-clamp-2 leading-tight mb-1 group-hover:text-primary transition-colors" x-text="item.title"></h4>
                        <p class="text-xs text-slate-500 font-medium mb-2 truncate"><i class="fa-solid fa-location-dot text-slate-300 mr-1"></i> <span x-text="item.location"></span></p>
                        
                        <div class="mt-auto pt-2 border-t border-slate-100 dark:border-slate-800">
                            <span class="text-primary font-black text-sm">UGX <span x-text="item.price"></span><span class="text-[10px] text-slate-400 font-bold ml-1 uppercase hidden sm:inline" x-text="item.period"></span></span>
                        </div>
                    </div>
                </div>
            </template>
        </div>

        <div x-show="viewMode === 'list'" class="space-y-3">
            <template x-for="item in getFeedItems()" :key="item.id">
                <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-md hover:border-primary/50 transition-all group cursor-pointer flex h-32 sm:h-40">
                    <div class="w-32 sm:w-48 flex-shrink-0 relative overflow-hidden bg-slate-100 dark:bg-slate-800">
                        <img :src="item.image" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold text-white shadow-sm" x-show="item.badge" x-text="item.badge"></div>
                    </div>
                    <div class="p-3 sm:p-4 flex flex-col flex-1 min-w-0 relative">
                        <button @click.stop="toggleSave(item.id)" class="absolute top-3 right-3 text-slate-300 hover:text-red-500 transition-colors z-10 hidden sm:block">
                            <i class="fa-solid fa-heart" :class="isSaved(item.id) ? 'text-red-500' : ''"></i>
                        </button>
                        
                        <h4 class="font-bold text-sm sm:text-base text-professional dark:text-white truncate group-hover:text-primary transition-colors pr-6" x-text="item.title"></h4>
                        <p class="text-xs text-slate-500 font-medium mb-1 truncate"><i class="fa-solid fa-location-dot text-slate-300 mr-1"></i> <span x-text="item.location"></span></p>
                        
                        <div class="flex items-center gap-2 mt-1 hidden sm:flex">
                            <span class="text-[10px] font-bold bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded text-slate-600 dark:text-slate-300"><i class="fa-solid fa-bed mr-1"></i> <span x-text="item.details.beds || '1'"></span></span>
                            <span class="text-[10px] font-bold bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded text-slate-600 dark:text-slate-300"><i class="fa-solid fa-bath mr-1"></i> <span x-text="item.details.baths || '1'"></span></span>
                        </div>

                        <div class="mt-auto flex justify-between items-end">
                            <span class="text-primary font-black text-sm sm:text-lg leading-none">UGX <span x-text="item.price"></span> <span class="text-[10px] text-slate-400 font-bold uppercase block sm:inline mt-0.5 sm:mt-0" x-text="item.period"></span></span>
                        </div>
                    </div>
                </div>
            </template>
        </div>
        
        <div class="py-10 flex justify-center">
            <button class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-400 hover:bg-primary hover:text-white transition-colors shadow-sm flex items-center justify-center">
                <i class="fa-solid fa-arrow-down"></i>
            </button>
        </div>
    </div>


    <div x-show="searchMode" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
         x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
         class="fixed inset-0 z-50 bg-white dark:bg-dark-bg sm:bg-slate-900/60 sm:backdrop-blur-sm sm:p-4 flex sm:items-start justify-center" style="display: none;">
        
        <div class="w-full h-full sm:h-auto sm:max-h-[90vh] sm:max-w-3xl sm:rounded-3xl bg-white dark:bg-dark-bg flex flex-col shadow-2xl overflow-hidden" @click.outside="closeSearchMode()">
            
            <div class="flex items-center gap-3 p-4 border-b border-slate-100 dark:border-slate-800 bg-white dark:bg-dark-surface z-10 shadow-[0_4px_20px_-2px_rgba(0,0,0,0.05)]">
                <button @click="closeSearchMode()" class="w-10 h-10 rounded-full flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors flex-shrink-0">
                    <i class="fa-solid fa-arrow-left text-lg"></i>
                </button>
                <div class="flex-1 relative">
                    <input type="text" x-model="searchQuery" x-ref="searchInput" 
                           class="w-full bg-slate-100 dark:bg-slate-800 border-none outline-none px-4 py-3 rounded-xl font-semibold text-professional dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-primary/20 transition-shadow"
                           :placeholder="`Search ${activeCategory} in Uganda...`"
                           autocomplete="off">
                    <button x-show="searchQuery" @click="searchQuery = ''" class="absolute right-3 top-3 text-slate-400 hover:text-slate-600"><i class="fa-solid fa-circle-xmark"></i></button>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-4 sm:p-6 bg-slate-50 dark:bg-dark-bg">
                
                <div x-show="searchQuery.length > 0" class="bg-white dark:bg-dark-surface rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden">
                    <template x-for="(sug, index) in getSuggestions()" :key="index">
                        <div class="flex items-center gap-4 p-4 border-b border-slate-50 dark:border-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800/50 cursor-pointer transition-colors last:border-0" @click="executeSearch(sug)">
                            <div class="w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 flex-shrink-0"><i class="fa-solid fa-magnifying-glass text-xs"></i></div>
                            <span class="font-semibold text-sm text-professional dark:text-slate-200" x-text="sug"></span>
                            <i class="fa-solid fa-arrow-right ml-auto text-slate-300 text-xs"></i>
                        </div>
                    </template>
                </div>

                <div x-show="searchQuery.length === 0" class="space-y-8">
                    
                    <div>
                        <h4 class="text-sm font-black text-professional dark:text-white mb-3">Recently Viewed</h4>
                        <div class="flex gap-3 overflow-x-auto hide-scrollbar pb-2">
                            <template x-for="item in recentViews" :key="item.id">
                                <div class="w-32 sm:w-40 flex-shrink-0 cursor-pointer group">
                                    <div class="w-full h-24 sm:h-28 rounded-xl bg-slate-200 dark:bg-slate-800 overflow-hidden relative border border-slate-200 dark:border-slate-700">
                                        <img :src="item.image" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                                        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-2">
                                            <span class="text-white font-bold text-[10px]" x-text="item.price + 'K'"></span>
                                        </div>
                                    </div>
                                    <p class="text-xs font-bold text-slate-700 dark:text-slate-300 mt-2 truncate group-hover:text-primary transition-colors" x-text="item.title"></p>
                                </div>
                            </template>
                        </div>
                    </div>

                    <div>
                        <h4 class="text-sm font-black text-professional dark:text-white mb-3">What Everyone is Searching</h4>
                        <div class="flex flex-wrap gap-2">
                            <template x-for="tag in getPopularTags()">
                                <button @click="searchQuery = tag; $refs.searchInput.focus()" 
                                        class="bg-white dark:bg-dark-surface border border-slate-200 dark:border-slate-700 px-4 py-2 rounded-full text-xs font-bold text-slate-600 dark:text-slate-300 hover:border-primary hover:text-primary transition-colors shadow-sm">
                                    <i class="fa-solid fa-arrow-trend-up text-accent mr-1"></i> <span x-text="tag"></span>
                                </button>
                            </template>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
function publicFeed() {
    return {
        // State
        activeCategory: 'hostels',
        viewMode: 'grid',
        searchMode: false,
        searchQuery: '',
        savedItems: [],

        // Config Data
        categories: [
            { id: 'hostels', label: 'Hostels', icon: 'fa-building-columns' },
            { id: 'hotels', label: 'Hotels', icon: 'fa-hotel' },
            { id: 'rentals', label: 'Rentals', icon: 'fa-house-user' },
            { id: 'commercial', label: 'Commercial', icon: 'fa-store' }
        ],

        // Mock Demo Data (This will be replaced by backend API calls)
        demoData: {
            hostels: [
                { id: 'h1', title: 'Olympia Premium Hostel', location: 'Makerere Kikoni, Kampala', price: '1,500', period: 'Semester', image: 'https://images.unsplash.com/photo-1555854877-bab0e564b8d5?q=80&w=400&auto=format&fit=crop', badge: 'Verified', details: { beds: 2, baths: 1 } },
                { id: 'h2', title: 'Nana Hostel', location: 'Kagugube, Kampala', price: '900', period: 'Semester', image: 'https://images.unsplash.com/photo-1522771731470-ea43374b422a?q=80&w=400&auto=format&fit=crop', badge: null, details: { beds: 1, baths: 1 } },
                { id: 'h3', title: 'Douglas Villa', location: 'Wandegeya, Kampala', price: '1,200', period: 'Semester', image: 'https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?q=80&w=400&auto=format&fit=crop', badge: 'Hot', details: { beds: 2, baths: 2 } }
            ],
            hotels: [
                { id: 'ht1', title: 'Kampala Serena Hotel', location: 'Kintu Road, Kampala', price: '950', period: 'Night', image: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=400&auto=format&fit=crop', badge: '5 Star', details: { beds: 1, baths: 1 } },
                { id: 'ht2', title: 'Speke Resort Munyonyo', location: 'Munyonyo, Kampala', price: '800', period: 'Night', image: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?q=80&w=400&auto=format&fit=crop', badge: 'Verified', details: { beds: 2, baths: 1 } }
            ],
            rentals: [
                { id: 'r1', title: 'Modern 2BR Apartment', location: 'Naalya, Kampala', price: '1,200', period: 'Month', image: 'https://images.unsplash.com/photo-1502672260266-1c1e541818bd?q=80&w=400&auto=format&fit=crop', badge: 'New', details: { beds: 2, baths: 2 } },
                { id: 'r2', title: 'Studio Flat - Tarmac Access', location: 'Kisaasi, Kampala', price: '450', period: 'Month', image: 'https://images.unsplash.com/photo-1493809842364-78817add7ffb?q=80&w=400&auto=format&fit=crop', badge: null, details: { beds: 1, baths: 1 } },
                { id: 'r3', title: 'Executive Bungalow', location: 'Kira, Wakiso', price: '2,500', period: 'Month', image: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?q=80&w=400&auto=format&fit=crop', badge: 'Verified', details: { beds: 3, baths: 3 } }
            ]
        },

        recentViews: [
            { id: 'v1', title: 'Olympia Hostel', price: '1,500', image: 'https://images.unsplash.com/photo-1555854877-bab0e564b8d5?q=80&w=200&auto=format&fit=crop' },
            { id: 'v2', title: '2BR Naalya', price: '1,200', image: 'https://images.unsplash.com/photo-1502672260266-1c1e541818bd?q=80&w=200&auto=format&fit=crop' }
        ],

        // Methods
        getFeedItems() {
            // If they click 'commercial' and we have no data, fallback to rentals for demo
            return this.demoData[this.activeCategory] || this.demoData.rentals;
        },

        toggleSave(id) {
            if(this.savedItems.includes(id)) {
                this.savedItems = this.savedItems.filter(i => i !== id);
            } else {
                this.savedItems.push(id);
            }
        },

        isSaved(id) {
            return this.savedItems.includes(id);
        },

        openSearchMode() {
            this.searchMode = true;
            // Prevent body scroll behind modal
            document.body.style.overflow = 'hidden';
            // Auto focus input after transition
            setTimeout(() => this.$refs.searchInput.focus(), 300);
        },

        closeSearchMode() {
            this.searchMode = false;
            this.searchQuery = '';
            document.body.style.overflow = 'auto';
        },

        resetSearch() {
            // Placeholder function for when tabs change
            console.log("Tab changed to:", this.activeCategory);
        },

        getPopularTags() {
            if(this.activeCategory === 'hostels') return ['Makerere', 'MUBS', 'Self Contained', 'Cheap Hostels'];
            if(this.activeCategory === 'hotels') return ['Entebbe', 'Swimming Pool', 'Honeymoon', 'Conference'];
            return ['2 Bedroom', 'Bungalow', 'Kira', 'Najjera', 'Fenced'];
        },

        getSuggestions() {
            const queries = [
                `Cheap ${this.activeCategory} in Kampala`,
                `Premium ${this.activeCategory} near me`,
                `Top rated ${this.activeCategory} in Wakiso`,
                `${this.activeCategory} with parking`
            ];
            // Filter dummy suggestions based on user input
            return queries.filter(q => q.toLowerCase().includes(this.searchQuery.toLowerCase()));
        },

        executeSearch(query) {
            this.searchQuery = query;
            // In a real app, this would trigger a fetch and close the modal
            setTimeout(() => {
                alert(`Searching for: ${query}`);
                this.closeSearchMode();
            }, 300);
        }
    }
}
</script>