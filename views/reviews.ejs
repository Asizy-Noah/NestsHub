<div class="bg-slate-50 dark:bg-dark-bg min-h-screen pb-12" x-data="publicReviews()" x-cloak>
    
    <header class="bg-white dark:bg-dark-surface border-b border-slate-200 dark:border-slate-800 sticky top-0 z-30 shadow-sm">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 h-16 flex items-center gap-4">
            <button @click="history.back()" class="w-10 h-10 rounded-full flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <i class="fa-solid fa-arrow-left"></i>
            </button>
            <div class="flex-1">
                <h1 class="text-lg font-black text-professional dark:text-white leading-tight" x-text="'Reviews for ' + targetName"></h1>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Public Feedback</p>
            </div>
        </div>
    </header>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-8">
        
        <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-glass flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-8">
            <div class="text-center sm:w-1/3">
                <h2 class="text-6xl font-black text-professional dark:text-white" x-text="stats.avg"></h2>
                <div class="flex justify-center text-amber-400 gap-1 my-2 text-lg">
                    <template x-for="i in 5"><i class="fa-solid" :class="i <= Math.round(stats.avg) ? 'fa-star' : 'fa-star text-slate-200 dark:text-slate-700'"></i></template>
                </div>
                <p class="text-xs font-bold text-slate-400 uppercase"><span x-text="stats.total"></span> Total Ratings</p>
            </div>

            <div class="flex-1 w-full space-y-3 border-t sm:border-t-0 sm:border-l border-slate-100 dark:border-slate-800 pt-6 sm:pt-0 sm:pl-8">
                <template x-for="score in [5,4,3,2,1]" :key="score">
                    <div class="flex items-center gap-3">
                        <span class="w-4 text-xs font-bold text-slate-500" x-text="score"></span>
                        <i class="fa-solid fa-star text-amber-400 text-[10px]"></i>
                        <div class="flex-1 h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-1000" :class="score >= 4 ? 'bg-primary' : (score === 3 ? 'bg-amber-400' : 'bg-red-400')" :style="`width: ${stats.distribution[score]}%`"></div>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <div class="flex gap-2 mb-6 overflow-x-auto hide-scrollbar">
            <template x-for="f in ['All', 'Positive', 'Critical']">
                <button @click="filter = f" class="px-5 py-2 rounded-full text-xs font-bold transition-colors border" :class="filter === f ? 'bg-professional text-white border-professional' : 'bg-white text-slate-500 border-slate-200 hover:border-slate-400'"><span x-text="f"></span></button>
            </template>
        </div>

        <div class="space-y-4">
            <template x-for="r in getFiltered()" :key="r.id">
                <div class="bg-white dark:bg-dark-surface rounded-2xl p-6 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <div class="flex justify-between items-start mb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center font-bold text-professional" x-text="r.author.charAt(0)"></div>
                            <div>
                                <p class="font-bold text-sm text-professional dark:text-white" x-text="r.author"></p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase" x-text="r.date"></p>
                            </div>
                        </div>
                        <div class="flex text-amber-400 text-[10px]"><template x-for="i in 5"><i class="fa-solid" :class="i <= r.rating ? 'fa-star' : 'fa-star text-slate-200'"></i></template></div>
                    </div>
                    <p class="text-sm text-slate-600 dark:text-slate-300 font-medium" x-text="r.comment"></p>
                </div>
            </template>
        </div>

    </div>
</div>

<script>
function publicReviews() {
    return {
        targetName: 'Olympia Premium Hostel', filter: 'All',
        stats: { avg: 4.8, total: 124, distribution: { 5: 80, 4: 10, 3: 5, 2: 3, 1: 2 } },
        reviews: [
            { id: 1, author: 'Sarah K.', date: 'Oct 12, 2026', rating: 5, comment: 'Excellent security and clean compound.' },
            { id: 2, author: 'Mike T.', date: 'Oct 01, 2026', rating: 3, comment: 'Good place but internet fluctuates on weekends.' }
        ],
        getFiltered() {
            if(this.filter === 'Positive') return this.reviews.filter(r => r.rating >= 4);
            if(this.filter === 'Critical') return this.reviews.filter(r => r.rating <= 3);
            return this.reviews;
        }
    }
}
</script>