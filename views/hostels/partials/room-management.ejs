<div x-data="roomManagement()" class="space-y-6">
  <!-- Add Room Button -->
  <div class="flex justify-end">
    <button @click="showAddRoomModal = true" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition flex items-center space-x-2">
      <i class="fas fa-plus"></i>
      <span>Add New Room</span>
    </button>
  </div>

  <!-- Room Gallery -->
  <div class="bg-white dark:bg-slate-800 rounded-lg card-shadow p-6">
    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-6">Room Gallery</h3>
    
    <div x-show="rooms.length === 0" class="text-center py-12">
      <i class="fas fa-door-open text-4xl text-slate-400 mb-4"></i>
      <p class="text-slate-600 dark:text-slate-400">No rooms added yet. Create your first room to get started.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" x-show="rooms.length > 0">
      <template x-for="room in rooms" :key="room._id">
        <div class="border border-slate-200 dark:border-slate-700 rounded-lg overflow-hidden hover:shadow-lg dark:hover:shadow-xl transition">
          <div class="h-40 bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center relative">
            <i class="fas fa-door-open text-4xl text-white opacity-50"></i>
            <span x-text="room.type" class="absolute bottom-2 right-2 bg-indigo-700 text-white px-2 py-1 rounded text-xs font-semibold uppercase"></span>
          </div>
          <div class="p-4">
            <h4 class="font-semibold text-slate-900 dark:text-white mb-2" x-text="'Room ' + room.roomNumber"></h4>
            <div class="space-y-2 text-sm text-slate-600 dark:text-slate-400 mb-4">
              <p><i class="fas fa-layer-group text-indigo-600 mr-2"></i><span x-text="'Floor ' + room.floor"></span></p>
              <p><i class="fas fa-users text-indigo-600 mr-2"></i><span x-text="room.capacity + ' bed(s)'"></span></p>
              <p x-show="room.isSelfContained"><i class="fas fa-bath text-indigo-600 mr-2"></i><span>Self Contained</span></p>
              <p><i class="fas fa-tags text-indigo-600 mr-2"></i><span x-text="'$' + room.pricePerMonth + '/month'"></span></p>
            </div>
            <div class="flex gap-2">
              <button @click="editRoom(room)" class="flex-1 px-3 py-2 bg-slate-100 dark:bg-slate-700 text-slate-900 dark:text-white rounded hover:bg-slate-200 dark:hover:bg-slate-600 transition text-sm">
                <i class="fas fa-edit mr-1"></i>Edit
              </button>
              <button @click="deleteRoom(room._id)" class="flex-1 px-3 py-2 bg-red-100 text-red-700 rounded hover:bg-red-200 transition text-sm">
                <i class="fas fa-trash mr-1"></i>Delete
              </button>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>

  <!-- Add/Edit Room Modal -->
  <div x-show="showAddRoomModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
    <div class="bg-white dark:bg-slate-800 rounded-lg max-w-2xl w-full max-h-96 overflow-y-auto">
      <div class="sticky top-0 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 p-6 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white" x-text="editingRoomId ? 'Edit Room' : 'Add New Room'"></h3>
        <button @click="showAddRoomModal = false" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>

      <form @submit="submitRoom" class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Room Number</label>
            <input type="text" x-model="roomForm.roomNumber" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-indigo-600 dark:bg-slate-700 dark:text-white" placeholder="e.g., 101, A1">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Floor</label>
            <div class="flex items-center space-x-2">
              <button type="button" @click="roomForm.floor = Math.max(0, roomForm.floor - 1)" class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded hover:bg-slate-200 dark:hover:bg-slate-600">−</button>
              <input type="number" x-model.number="roomForm.floor" class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-indigo-600 dark:bg-slate-700 dark:text-white text-center">
              <button type="button" @click="roomForm.floor = roomForm.floor + 1" class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded hover:bg-slate-200 dark:hover:bg-slate-600">+</button>
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-3">Room Type</label>
          <div class="grid grid-cols-2 gap-4">
            <label class="relative">
              <input type="radio" x-model="roomForm.type" value="single" class="sr-only">
              <div class="p-4 border-2 rounded-lg cursor-pointer transition" :class="roomForm.type === 'single' ? 'border-indigo-600 bg-indigo-50 dark:bg-indigo-900' : 'border-slate-300 dark:border-slate-600'">
                <i class="fas fa-bed text-2xl text-indigo-600 mb-2"></i>
                <p class="font-semibold text-slate-900 dark:text-white">Single</p>
                <p class="text-sm text-slate-600 dark:text-slate-400">1 bed</p>
              </div>
            </label>
            <label class="relative">
              <input type="radio" x-model="roomForm.type" value="double" class="sr-only">
              <div class="p-4 border-2 rounded-lg cursor-pointer transition" :class="roomForm.type === 'double' ? 'border-indigo-600 bg-indigo-50 dark:bg-indigo-900' : 'border-slate-300 dark:border-slate-600'">
                <i class="fas fa-bed text-2xl text-indigo-600 mb-2"></i>
                <p class="font-semibold text-slate-900 dark:text-white">Double</p>
                <p class="text-sm text-slate-600 dark:text-slate-400">2 beds</p>
              </div>
            </label>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Capacity</label>
            <input type="number" x-model.number="roomForm.capacity" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-indigo-600 dark:bg-slate-700 dark:text-white" placeholder="Number of beds">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Price per Month ($)</label>
            <input type="number" x-model.number="roomForm.pricePerMonth" class="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg focus:ring-2 focus:ring-indigo-600 dark:bg-slate-700 dark:text-white" placeholder="0">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-3">Cooking Policy</label>
          <div class="space-y-2">
            <label class="flex items-center space-x-2 cursor-pointer">
              <input type="radio" x-model="roomForm.cookingPolicy" value="electricity" class="w-4 h-4">
              <span class="text-slate-700 dark:text-slate-300">Electricity only</span>
            </label>
            <label class="flex items-center space-x-2 cursor-pointer">
              <input type="radio" x-model="roomForm.cookingPolicy" value="gas" class="w-4 h-4">
              <span class="text-slate-700 dark:text-slate-300">Gas cooking allowed</span>
            </label>
            <label class="flex items-center space-x-2 cursor-pointer">
              <input type="radio" x-model="roomForm.cookingPolicy" value="not_allowed" class="w-4 h-4">
              <span class="text-slate-700 dark:text-slate-300">Not allowed</span>
            </label>
          </div>
        </div>

        <div class="flex items-center space-x-3 p-4 bg-slate-50 dark:bg-slate-700 rounded-lg">
          <input type="checkbox" x-model="roomForm.isSelfContained" class="w-4 h-4">
          <label class="text-slate-700 dark:text-slate-300">
            <span class="font-medium">Self Contained</span>
            <p class="text-sm text-slate-600 dark:text-slate-400">Room has its own bathroom</p>
          </label>
        </div>

        <div class="flex justify-end space-x-3 pt-4">
          <button type="button" @click="showAddRoomModal = false" class="px-6 py-2 border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition">
            Cancel
          </button>
          <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition">
            <span x-text="editingRoomId ? 'Update Room' : 'Add Room'"></span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function roomManagement() {
    return {
      rooms: <%= JSON.stringify(rooms || []) %>,
      showAddRoomModal: false,
      editingRoomId: null,
      roomForm: {
        roomNumber: '',
        type: 'single',
        floor: 0,
        capacity: 1,
        pricePerMonth: 0,
        cookingPolicy: 'not_allowed',
        isSelfContained: false,
      },

      resetRoomForm() {
        this.roomForm = {
          roomNumber: '',
          type: 'single',
          floor: 0,
          capacity: 1,
          pricePerMonth: 0,
          cookingPolicy: 'not_allowed',
          isSelfContained: false,
        };
        this.editingRoomId = null;
      },

      editRoom(room) {
        this.roomForm = { ...room };
        this.editingRoomId = room._id;
        this.showAddRoomModal = true;
      },

      async submitRoom(e) {
        e.preventDefault();
        const url = this.editingRoomId 
          ? `/hostels/<%= hostel._id %>/rooms/${this.editingRoomId}`
          : `/hostels/<%= hostel._id %>/rooms`;
        const method = this.editingRoomId ? 'PUT' : 'POST';

        try {
          const response = await fetch(url, {
            method,
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer ' + localStorage.getItem('token'),
            },
            body: JSON.stringify(this.roomForm),
          });

          if (response.ok) {
            const data = await response.json();
            if (this.editingRoomId) {
              const idx = this.rooms.findIndex(r => r._id === this.editingRoomId);
              this.rooms[idx] = data;
            } else {
              this.rooms.push(data);
            }
            this.showAddRoomModal = false;
            this.resetRoomForm();
            showToast(this.editingRoomId ? 'Room updated successfully!' : 'Room added successfully!', 'success');
          }
        } catch (error) {
          showToast('Error: ' + error.message, 'error');
        }
      },

      async deleteRoom(roomId) {
        if (!confirm('Are you sure you want to delete this room?')) return;

        try {
          const response = await fetch(`/hostels/<%= hostel._id %>/rooms/${roomId}`, {
            method: 'DELETE',
            headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') },
          });

          if (response.ok) {
            this.rooms = this.rooms.filter(r => r._id !== roomId);
            showToast('Room deleted successfully!', 'success');
          }
        } catch (error) {
          showToast('Error: ' + error.message, 'error');
        }
      }
    };
  }
</script>
