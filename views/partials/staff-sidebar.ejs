<aside class="w-64 bg-slate-900 text-white flex flex-col h-screen fixed left-0 top-0 overflow-y-auto">
  <!-- Logo -->
  <div class="p-6 border-b border-slate-700">
    <h2 class="text-2xl font-bold text-blue-400">Staff Panel</h2>
  </div>

  <!-- Navigation Menu -->
  <nav class="flex-1 p-4 space-y-2">
    <a href="/dashboard/staff" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path === '/dashboard/staff' ? 'bg-blue-500' : '' %>">
      <i class="fas fa-home w-5"></i> Dashboard
    </a>

    <a href="/dashboard/staff/hostels" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path.includes('/hostels') ? 'bg-blue-500' : '' %>">
      <i class="fas fa-hotel w-5"></i> Hostels
    </a>

    <a href="/dashboard/staff/hotels" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path.includes('/hotels') ? 'bg-blue-500' : '' %>">
      <i class="fas fa-building w-5"></i> Hotels
    </a>

    <a href="/dashboard/staff/rentals" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path.includes('/rentals') ? 'bg-blue-500' : '' %>">
      <i class="fas fa-house w-5"></i> Rentals
    </a>

    <a href="/dashboard/staff/property-owners" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path.includes('/property-owners') ? 'bg-blue-500' : '' %>">
      <i class="fas fa-user-tie w-5"></i> Property Owners
    </a>

    <a href="/dashboard/staff/brokers" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path.includes('/brokers') ? 'bg-blue-500' : '' %>">
      <i class="fas fa-handshake w-5"></i> Brokers
    </a>

    <a href="/blogs" class="block px-4 py-3 rounded-lg hover:bg-slate-800 transition <%= request.path.includes('/blogs') ? 'bg-blue-500' : '' %>">
      <i class="fas fa-blog w-5"></i> Blogs
    </a>
  </nav>

  <!-- User Info & Logout -->
  <div class="p-4 border-t border-slate-700 space-y-2">
    <div class="text-sm text-slate-400">
      <p class="font-semibold"><%= user.firstName %> <%= user.lastName %></p>
      <p><%= user.email %></p>
    </div>
    <a href="/auth/logout" class="block w-full text-center px-4 py-2 bg-red-600 hover:bg-red-700 rounded-lg transition">
      <i class="fas fa-sign-out-alt w-5"></i> Logout
    </a>
  </div>
</aside>

<!-- Main content margin -->
<style>
  .staff-layout {
    margin-left: 16rem; /* w-64 = 16rem */
  }
</style>
