<div x-data="hotelRoomDetails(<%= typeof payload !== 'undefined' ? payload : '{}' %>)" class="bg-slate-50 dark:bg-dark-bg min-h-screen pb-24 sm:pb-8" x-cloak>
    
    <div class="relative w-full h-[40vh] sm:h-[60vh] bg-slate-200 dark:bg-slate-900 group overflow-hidden">
        <div class="flex h-full w-full overflow-x-auto snap-x snap-mandatory hide-scrollbar" @scroll="updateActiveImage($event)">
            <template x-for="(img, index) in allPhotos" :key="index">
                <div class="w-full h-full flex-shrink-0 snap-center relative">
                    <img :src="img" class="w-full h-full object-cover cursor-pointer" @click="openGallery(index)">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20 pointer-events-none"></div>
                </div>
            </template>
            <div x-show="allPhotos.length === 0" class="w-full h-full flex items-center justify-center text-slate-400">
                <i class="fa-solid fa-hotel text-6xl"></i>
            </div>
        </div>

        <div class="absolute top-0 inset-x-0 p-4 flex justify-between items-start z-10">
            <button @click="history.back()" class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors shadow-sm"><i class="fa-solid fa-arrow-left"></i></button>
            <div class="flex gap-2">
                <button class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors shadow-sm"><i class="fa-solid fa-share-nodes"></i></button>
                <button @click="toggleSave()" class="w-10 h-10 rounded-full bg-black/40 backdrop-blur-md text-white flex items-center justify-center hover:bg-black/60 transition-colors shadow-sm"><i class="fa-solid fa-heart" :class="isSaved ? 'text-red-500' : ''"></i></button>
            </div>
        </div>

        <div x-show="allPhotos.length > 1" class="absolute bottom-4 right-4 bg-black/60 backdrop-blur-md text-white text-xs font-black px-3 py-1.5 rounded-full z-10 shadow-sm flex items-center gap-2"><i class="fa-regular fa-image"></i> <span x-text="`${activeImageIndex + 1} / ${allPhotos.length}`"></span></div>
        <div x-show="hotel.isVerified" class="absolute bottom-4 left-4 bg-primary/90 backdrop-blur-md text-white text-[10px] uppercase font-black px-3 py-1.5 rounded-full z-10 shadow-lg flex items-center gap-1"><i class="fa-solid fa-shield-check"></i> Verified Hotel</div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-20">
        
        <div class="bg-white dark:bg-dark-surface rounded-3xl shadow-glass p-6 sm:p-8 mb-6 border border-slate-100 dark:border-slate-800">
            <div class="flex justify-between items-start mb-2">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-black text-professional dark:text-white leading-tight mb-2" x-text="room.type"></h1>
                    <p class="text-sm font-semibold text-slate-500 dark:text-slate-400 flex items-center gap-2">
                        <i class="fa-solid fa-location-dot text-slate-300"></i>
                        <a :href="'/public/hotels/' + hotel._id" class="hover:text-primary transition-colors font-bold" x-text="hotel.name"></a>
                        <span x-text="' • ' + (hotel.street || '') + ', ' + (hotel.town || hotel.districtOrCity || '')"></span>
                    </p>
                </div>
            </div>
            
            <div class="mt-6 pt-6 border-t border-slate-100 dark:border-slate-800 flex items-end justify-between">
                <div>
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Room Rate</p>
                    <div class="flex items-baseline gap-1 text-primary"><span class="text-xl font-bold">UGX</span><span class="text-3xl sm:text-4xl font-black" x-text="Number(room.price).toLocaleString()"></span></div>
                    <p class="text-xs font-bold text-slate-500 mt-1 uppercase" x-text="room.pricingPeriod || 'Per Night'"></p>
                </div>
                <div class="text-right">
                    <span class="inline-block px-3 py-1 rounded-lg text-xs font-black uppercase tracking-wider mb-1" :class="room.availableRooms > 0 ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'" x-text="room.availableRooms > 0 ? 'Available' : 'Sold Out'"></span>
                    <p class="text-[10px] font-bold text-slate-400"><span x-text="room.availableRooms"></span> rooms left</p>
                </div>
            </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-6">
            
            <div class="lg:w-2/3 space-y-6">
                
                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-6 flex items-center gap-2"><i class="fa-solid fa-list-check text-primary"></i> Room Specifications</h3>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-8">
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-bed w-4 text-center text-slate-300"></i> Bed Type</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.bedSize || 'Standard'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-mug-hot w-4 text-center text-slate-300"></i> Board Basis</span>
                            <span class="text-sm font-bold" :class="room.bedAndBreakfast ? 'text-primary' : 'text-slate-600 dark:text-slate-400'" x-text="room.bedAndBreakfast ? 'Breakfast Included' : 'Room Only'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-bath w-4 text-center text-slate-300"></i> Bathroom</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.isSelfContained ? 'En-suite Bath' : 'Shared'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-shower w-4 text-center text-slate-300"></i> Hot Water</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.hotWater ? 'Available' : 'No'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-tv w-4 text-center text-slate-300"></i> Entertainment</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.hasTV ? 'Smart TV / DSTV' : 'None'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-fan w-4 text-center text-slate-300"></i> Climate</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.hasAC ? 'Air Conditioned' : 'Standard Fan'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-laptop w-4 text-center text-slate-300"></i> Workspace</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.workingTable ? 'Desk Provided' : 'None'"></span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-slate-50 dark:border-slate-800/50">
                            <span class="text-sm text-slate-500 font-medium flex items-center gap-2"><i class="fa-solid fa-cloud-sun w-4 text-center text-slate-300"></i> Balcony</span>
                            <span class="text-sm font-bold text-professional dark:text-white" x-text="room.hasBalcony ? 'Private Balcony' : 'None'"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-4">About this Room</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed" x-text="generateRoomDescription()"></p>
                </div>

                <div class="bg-white dark:bg-dark-surface rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-lg font-black text-professional dark:text-white mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-hotel text-primary"></i> About <a :href="'/public/hotels/' + hotel._id" class="hover:underline" x-text="hotel.name"></a>
                    </h3>
                    
                    <div class="grid grid-cols-2 gap-4 mb-8">
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-4 rounded-2xl border border-slate-100 dark:border-slate-700/50">
                            <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Distance to Center</p>
                            <p class="text-base font-black text-professional dark:text-white"><span x-text="hotel.distanceFromTown || 0"></span> km</p>
                        </div>
                        <div class="bg-slate-50 dark:bg-slate-800/50 p-4 rounded-2xl border border-slate-100 dark:border-slate-700/50">
                            <p class="text-[10px] font-bold text-slate-400 uppercase mb-1">Accessibility</p>
                            <p class="text-base font-black text-professional dark:text-white" x-text="hotel.accessTarmacked ? 'Tarmacked Road' : 'Off-Road Access'"></p>
                        </div>
                    </div>

                    <h4 class="text-sm font-bold text-slate-700 dark:text-slate-300 mb-4 uppercase tracking-wider border-b border-slate-100 dark:border-slate-800 pb-2">Hotel Facilities</h4>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-5 gap-x-4">
                        <template x-for="(value, key) in hotel.amenities" :key="key">
                            <div x-show="value" class="flex items-center gap-3 text-sm font-semibold text-slate-600 dark:text-slate-300">
                                <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                                    <i class="fa-solid fa-check text-xs"></i>
                                </div>
                                <span class="capitalize" x-text="key.replace(/([A-Z])/g, ' $1').trim()"></span>
                            </div>
                        </template>
                    </div>
                </div>
            </div>

            <div class="lg:w-1/3 space-y-6">
                <div class="sticky top-24 space-y-6">
                    
                    <div class="bg-white dark:bg-dark-surface rounded-3xl p-4 shadow-glass border border-slate-100 dark:border-slate-800 flex flex-col gap-3">
                        <a :href="`tel:${hotel.phones && hotel.phones[0] ? hotel.phones[0] : ''}`" class="btn-primary w-full py-4 text-base shadow-lg"><i class="fa-solid fa-phone-volume"></i> Call Reception</a>
                        <div class="flex gap-3">
                            <a :href="`https://wa.me/${hotel.whatsapps && hotel.whatsapps[0] ? hotel.whatsapps[0] : ''}`" target="_blank" class="flex-1 bg-[#25D366]/10 text-[#25D366] hover:bg-[#25D366] hover:text-white rounded-xl py-3 flex items-center justify-center gap-2 font-bold transition-colors"><i class="fa-brands fa-whatsapp text-lg"></i> WhatsApp</a>
                            <button @click="alert('Inquiries coming soon!')" class="flex-1 bg-slate-100 dark:bg-slate-800 text-professional dark:text-white hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl py-3 flex items-center justify-center gap-2 font-bold transition-colors"><i class="fa-regular fa-comment-dots text-lg"></i> Inquire</button>
                        </div>
                    </div>

                    <a :href="'/public/hotels/' + hotel._id" class="block bg-white dark:bg-dark-surface rounded-3xl p-6 border border-slate-100 dark:border-slate-800 shadow-sm text-center hover:shadow-md hover:border-primary/50 transition-all group">
                        <div class="w-24 h-24 mx-auto rounded-2xl bg-slate-100 dark:bg-slate-800 border-2 border-slate-50 dark:border-dark-surface shadow-sm overflow-hidden mb-4 relative">
                            <img :src="hotel.profilePhoto || 'https://ui-avatars.com/api/?name=' + hotel.name" class="w-full h-full object-cover">
                            <div x-show="hotel.isVerified" class="absolute bottom-0 right-0 w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center text-[10px] border-2 border-white"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <h4 class="font-black text-professional dark:text-white text-xl group-hover:text-primary transition-colors leading-tight" x-text="hotel.name"></h4>
                        <p class="text-xs font-bold text-slate-400 mt-1.5 uppercase tracking-wider">Official Profile</p>
                        
                        <div class="mt-6 pt-4 border-t border-slate-100 dark:border-slate-800 flex justify-center items-center gap-2 text-sm font-bold text-primary group-hover:underline">
                            View All Rooms & Reviews <i class="fa-solid fa-arrow-right"></i>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800" x-show="comparisonRooms.length > 0">
            <h3 class="text-xl font-black text-professional dark:text-white mb-6">Compare Similar <span x-text="room.type"></span>s</h3>
            
            <div class="flex gap-3 sm:gap-4 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-6 relative items-stretch">
                <div class="w-40 sm:w-64 flex-shrink-0 sticky left-0 z-20 bg-slate-50 dark:bg-dark-bg pr-3 sm:pr-4 -ml-4 pl-4 snap-start">
                    <div class="bg-primary/5 border-2 border-primary rounded-2xl h-full shadow-lg overflow-hidden flex flex-col relative">
                        <div class="absolute top-0 inset-x-0 bg-primary text-white text-[8px] sm:text-[10px] font-black uppercase text-center py-1 z-10">Current</div>
                        <div class="h-24 sm:h-32 bg-slate-200 relative overflow-hidden"><img :src="allPhotos[0]" class="w-full h-full object-cover"></div>
                        <div class="p-3 sm:p-4 flex-1 flex flex-col">
                            <h4 class="font-bold text-xs sm:text-sm text-professional dark:text-white truncate" x-text="hotel.name"></h4>
                            <p class="text-[10px] sm:text-xs text-slate-500 mb-2 truncate" x-text="hotel.town || hotel.districtOrCity"></p>
                            <div class="mt-auto text-primary font-black text-xs sm:text-base">UGX <span x-text="Number(room.price).toLocaleString()"></span></div>
                        </div>
                    </div>
                </div>

                <template x-for="comp in comparisonRooms" :key="comp.id">
                    <a :href="'/public/hotels/room/' + comp.id" class="w-40 sm:w-64 flex-shrink-0 bg-white dark:bg-dark-surface rounded-2xl border border-slate-200 dark:border-slate-700 h-full overflow-hidden shadow-sm hover:shadow-md hover:border-slate-300 transition-all flex flex-col relative z-10 group snap-start">
                        <div class="h-24 sm:h-32 bg-slate-100 relative overflow-hidden"><img :src="comp.image" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" @error="$event.target.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=400'"></div>
                        <div class="p-3 sm:p-4 flex-1 flex flex-col">
                            <h4 class="font-bold text-xs sm:text-sm text-professional dark:text-white truncate group-hover:text-primary transition-colors" x-text="comp.hotelName"></h4>
                            <p class="text-[10px] sm:text-xs text-slate-500 mb-2 truncate" x-text="comp.location"></p>
                            <div class="mt-auto text-slate-700 dark:text-slate-300 font-black text-xs sm:text-base">UGX <span x-text="Number(comp.price).toLocaleString()"></span></div>
                        </div>
                    </a>
                </template>
            </div>
        </div>

        <div class="mt-8 pt-8 border-t border-slate-200 dark:border-slate-800" x-show="otherRooms.length > 0">
            <div class="flex justify-between items-end mb-6">
                <h3 class="text-xl font-black text-professional dark:text-white">More Options to Consider</h3>
                <div class="flex bg-slate-200 dark:bg-slate-800 p-1 rounded-lg">
                    <button @click="viewMode = 'grid'" class="w-8 h-8 rounded flex items-center justify-center transition-colors" :class="viewMode === 'grid' ? 'bg-white dark:bg-slate-700 text-primary shadow-sm' : 'text-slate-400'"><i class="fa-solid fa-grip"></i></button>
                    <button @click="viewMode = 'list'" class="w-8 h-8 rounded flex items-center justify-center transition-colors" :class="viewMode === 'list' ? 'bg-white dark:bg-slate-700 text-primary shadow-sm' : 'text-slate-400'"><i class="fa-solid fa-list"></i></button>
                </div>
            </div>

            <div x-show="viewMode === 'grid'" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
                <template x-for="item in otherRooms" :key="item.id">
                    <a :href="item.url" class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-lg hover:border-primary/50 transition-all group flex flex-col h-full relative">
                        <div class="relative w-full pt-[85%] bg-slate-100 overflow-hidden">
                            <img :src="item.image" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" @error="$event.target.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=400'">
                            <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold text-white shadow-sm" x-show="item.badge" x-text="item.badge"></div>
                        </div>
                        <div class="p-3 flex flex-col flex-1">
                            <h4 class="font-bold text-sm text-professional dark:text-white line-clamp-2 leading-tight mb-1 group-hover:text-primary transition-colors" x-text="item.title"></h4>
                            <p class="text-xs text-slate-500 font-medium mb-2 truncate"><i class="fa-solid fa-location-dot text-slate-300 mr-1"></i> <span x-text="item.location"></span></p>
                            
                            <div class="flex flex-wrap gap-1 mb-2 mt-auto">
                                <template x-for="(am, index) in item.amenities" :key="index">
                                    <span class="text-[9px] font-bold bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 text-slate-500 dark:text-slate-400 px-1.5 py-0.5 rounded whitespace-nowrap">
                                        <i class="fa-solid mr-1 text-slate-400" :class="am.icon"></i><span x-text="am.text"></span>
                                    </span>
                                </template>
                            </div>

                            <div class="pt-2 border-t border-slate-100 dark:border-slate-800">
                                <span class="text-primary font-black text-sm">UGX <span x-text="Number(item.price).toLocaleString()"></span></span>
                            </div>
                        </div>
                    </a>
                </template>
            </div>

            <div x-show="viewMode === 'list'" class="space-y-3">
                <template x-for="item in otherRooms" :key="item.id">
                    <a :href="item.url" class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-md hover:border-primary/50 transition-all group flex h-36 sm:h-40">
                        <div class="w-32 sm:w-48 flex-shrink-0 relative overflow-hidden bg-slate-100 dark:bg-slate-800">
                            <img :src="item.image" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" @error="$event.target.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=400'">
                            <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold text-white shadow-sm" x-show="item.badge" x-text="item.badge"></div>
                        </div>
                        <div class="p-3 sm:p-4 flex flex-col flex-1 min-w-0 relative">
                            <h4 class="font-bold text-sm sm:text-base text-professional dark:text-white truncate group-hover:text-primary transition-colors pr-6" x-text="item.title"></h4>
                            <p class="text-xs text-slate-500 font-medium mb-1 truncate"><i class="fa-solid fa-location-dot text-slate-300 mr-1"></i> <span x-text="item.location"></span></p>
                            
                            <div class="flex flex-wrap gap-1.5 mt-1">
                                <template x-for="(am, index) in item.amenities" :key="index">
                                    <span class="text-[9px] sm:text-[10px] font-bold bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 px-2 py-0.5 sm:py-1 rounded text-slate-500 dark:text-slate-400 whitespace-nowrap">
                                        <i class="fa-solid mr-1 text-slate-400" :class="am.icon"></i><span x-text="am.text"></span>
                                    </span>
                                </template>
                            </div>

                            <div class="mt-auto flex justify-between items-end">
                                <span class="text-primary font-black text-sm sm:text-lg leading-none">UGX <span x-text="Number(item.price).toLocaleString()"></span></span>
                            </div>
                        </div>
                    </a>
                </template>
            </div>
        </div>
    </div>

    <div class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl border-t border-slate-200 dark:border-slate-800 p-4 pb-safe flex gap-3 transition-transform duration-300"
         :class="showMobileContact ? 'translate-y-0' : 'translate-y-full'">
        <a :href="`tel:${hotel.phones && hotel.phones[0] ? hotel.phones[0] : ''}`" class="flex-1 btn-primary py-3 shadow-lg"><i class="fa-solid fa-phone"></i> Call</a>
        <a :href="`https://wa.me/${hotel.whatsapps && hotel.whatsapps[0] ? hotel.whatsapps[0] : ''}`" target="_blank" class="w-14 bg-[#25D366]/10 text-[#25D366] rounded-xl flex items-center justify-center text-xl"><i class="fa-brands fa-whatsapp"></i></a>
    </div>

    <div x-show="galleryOpen" class="fixed inset-0 z-[100] bg-black flex flex-col" style="display: none;">
        <div class="p-4 flex justify-between items-center text-white">
            <span class="font-bold text-sm" x-text="`${activeImageIndex + 1} / ${allPhotos.length}`"></span>
            <button @click="galleryOpen = false" class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center hover:bg-white/40"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="flex-1 relative flex items-center justify-center overflow-hidden">
            <img :src="allPhotos[activeImageIndex]" class="max-w-full max-h-full object-contain">
            <button @click="activeImageIndex = (activeImageIndex - 1 + allPhotos.length) % allPhotos.length" class="absolute left-4 w-12 h-12 bg-black/50 text-white rounded-full flex items-center justify-center hover:bg-black/80"><i class="fa-solid fa-chevron-left"></i></button>
            <button @click="activeImageIndex = (activeImageIndex + 1) % allPhotos.length" class="absolute right-4 w-12 h-12 bg-black/50 text-white rounded-full flex items-center justify-center hover:bg-black/80"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>
</div>

<script>
function hotelRoomDetails(serverData) {
    const room = serverData?.room || {};
    const hotel = serverData?.hotel || {};

    return {
        // Robust Fallbacks based on your EXACT Hotel/HotelRoom schemas
        room: Object.assign({ type: 'Standard', price: 0, availableRooms: 0, totalRooms: 0, bedSize: 'Standard Double', bedAndBreakfast: false, isSelfContained: false, hasBalcony: false, hasAC: false, workingTable: false, hotWater: false, hasTV: false, isAccessible: false, pricingPeriod: 'Night', photos: [] }, room),
        hotel: Object.assign({ _id: '', name: 'Hotel', districtOrCity: '', town: '', street: '', distanceFromTown: 0, accessTarmacked: false, phones: [''], whatsapps: [''], gallery: [], isVerified: false, profilePhoto: '', amenities: {} }, hotel),
        
        comparisonRooms: serverData?.comparisonRooms || [],
        otherRooms: serverData?.otherRooms || [],
        
        viewMode: 'grid',
        allPhotos: [...(room.photos || []), ...(hotel.gallery || [])],
        activeImageIndex: 0, galleryOpen: false, isSaved: false, showMobileContact: false,

        init() { window.addEventListener('scroll', () => { this.showMobileContact = window.scrollY > 300; }); },
        updateActiveImage(e) { this.activeImageIndex = Math.round(e.target.scrollLeft / e.target.offsetWidth); },
        openGallery(index) { this.activeImageIndex = index; this.galleryOpen = true; },
        toggleSave() { this.isSaved = !this.isSaved; },
        
        generateRoomDescription() {
            let desc = `Experience comfort and luxury in this ${this.room.type}. `;
            desc += `The room is equipped with a comfortable ${this.room.bedSize || 'Standard Bed'} and `;
            
            let features = [];
            if(this.room.hasAC) features.push('air conditioning');
            if(this.room.hasBalcony) features.push('a private balcony');
            if(this.room.hasTV) features.push('a Smart TV');
            if(this.room.hotWater) features.push('hot water');
            
            if(features.length > 0) {
                desc += features.join(', ').replace(/, ([^,]*)$/, ' and $1') + '. ';
            } else {
                desc += 'standard amenities. ';
            }

            if(this.room.bedAndBreakfast) desc += `Your stay includes complimentary breakfast. `;
            if(this.room.workingTable) desc += `A dedicated workspace is provided for your convenience. `;
            if(this.room.isAccessible) desc += `This room is fully accessible for persons with disabilities.`;
            
            return desc;
        }
    }
}
</script>