<div class="w-full max-w-lg mx-auto" x-data="forgotPasswordFlow()">
    
    <div class="mb-12 relative">
        <div class="absolute top-1/2 left-0 w-full h-1 bg-slate-200 dark:bg-slate-800 -translate-y-1/2 rounded-full z-0"></div>
        <div class="absolute top-1/2 left-0 h-1 bg-accent -translate-y-1/2 rounded-full z-0 transition-all duration-500" :style="'width: ' + ((step - 1) * 50) + '%'"></div>
        
        <div class="flex justify-between relative z-10">
            <template x-for="(label, index) in ['Enter Email', 'Check Mail', 'New Password']">
                <div class="flex flex-col items-center gap-2">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm shadow-md transition-colors duration-500"
                         :class="step > index ? 'bg-accent text-white' : (step === index + 1 ? 'bg-accent text-white ring-4 ring-accent/30' : 'bg-light-surface dark:bg-dark-surface text-slate-400 border-2 border-slate-200 dark:border-slate-700')">
                        <i class="fa-solid" :class="index === 0 ? 'fa-at' : (index === 1 ? 'fa-envelope-open-text' : 'fa-key')"></i>
                    </div>
                    <span class="text-xs font-semibold uppercase tracking-wider" :class="step >= index + 1 ? 'text-professional dark:text-white' : 'text-slate-400'" x-text="label"></span>
                </div>
            </template>
        </div>
    </div>

    <div class="card relative overflow-hidden">
        
        <form @submit.prevent="submitEmail" x-show="step === 1" x-transition.opacity>
            <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-professional dark:text-white mb-2">Reset Password</h2>
                <p class="text-slate-500">Enter your registered email address to receive reset instructions.</p>
            </div>

            <div class="input-group mb-8">
                <label>Email Address</label>
                <input type="email" x-model="email" required class="input-field" placeholder="you@example.com">
                <i class="fa-regular fa-envelope input-icon"></i>
            </div>

            <button type="submit" class="btn-accent w-full" :disabled="loading">
                <span x-show="!loading">Send Reset Link</span>
                <span x-show="loading"><i class="fa-solid fa-circle-notch fa-spin"></i> Sending...</span>
            </button>
        </form>

        <div x-show="step === 2" x-transition.opacity x-cloak class="text-center py-6">
            <div class="w-20 h-20 bg-accent/10 text-accent rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fa-regular fa-paper-plane text-4xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-professional dark:text-white mb-4">Link Sent Successfully</h2>
            <p class="text-slate-500 mb-8 max-w-sm mx-auto">We've sent password reset instructions to <strong class="text-professional dark:text-white" x-text="email"></strong>.</p>
            
            <a href="/auth/login" class="btn-outline w-full justify-center">Return to Login</a>
        </div>
    </div>
</div>

<script>
function forgotPasswordFlow() {
    return {
        step: 1,
        email: '',
        loading: false,
        async submitEmail() {
            this.loading = true;
            try {
                const response = await fetch('/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: this.email }),
                });

                // We don't necessarily need to check response.ok here 
                // because your backend returns success regardless of 
                // whether the email exists (for security).
                this.step = 2; 
            } catch (err) {
                console.error("Reset Error:", err);
                alert("Something went wrong. Please try again later.");
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>