<%- include('../layout', { title, body: `
<div class="max-w-md mx-auto px-4 py-12" x-data="forgotPasswordForm()" x-cloak>
    <div class="card">
        <h1 class="text-3xl font-bold text-center mb-8">Reset Password</h1>

        <!-- Error Messages -->
        <div x-show="error" class="alert-error mb-6">
            <span x-text="error"></span>
            <button @click="error = ''" class="float-right text-xl">&times;</button>
        </div>

        <!-- Success Message -->
        <div x-show="success" class="alert-success mb-6">
            <p class="font-medium">Check Your Email</p>
            <p class="text-sm mt-2">
                We've sent a password reset link to <strong x-text="formData.email"></strong>
            </p>
        </div>

        <form @submit.prevent="submitForm()" class="space-y-6" x-show="!success">
            <p class="text-gray-600 dark-mode:text-gray-400 mb-4">
                Enter your email address and we'll send you a link to reset your password.
            </p>

            <div>
                <label class="block text-sm font-medium mb-2">Email Address</label>
                <input 
                    type="email" 
                    x-model="formData.email" 
                    class="input-field"
                    placeholder="you@example.com"
                    required
                >
            </div>

            <button 
                type="submit" 
                class="btn-primary w-full"
                :disabled="loading"
                x-text="loading ? 'Sending Link...' : 'Send Reset Link'"
            ></button>
        </form>

        <p class="text-center text-gray-600 dark-mode:text-gray-400 mt-6">
            Remember your password? <a href="/auth/login" class="text-blue-600 hover:underline">Sign in</a>
        </p>
    </div>
</div>

<script>
function forgotPasswordForm() {
    return {
        loading: false,
        error: '',
        success: false,
        formData: {
            email: '',
        },

        async submitForm() {
            this.loading = true;
            this.error = '';

            try {
                const response = await fetch('/auth/forgot-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(this.formData),
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Request failed');
                }

                this.success = true;
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>
`) %>
