<div class="w-full max-w-md mx-auto" x-data="resetPasswordForm('<%= typeof token !== 'undefined' ? token : '' %>')">
    
    <div class="text-center mb-10">
        <div class="w-16 h-16 bg-accent/10 text-accent rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-sm">
            <i class="fa-solid fa-unlock-keyhole text-3xl"></i>
        </div>
        <h1 class="text-3xl font-extrabold text-professional dark:text-white mb-2">Reset Password</h1>
        <p class="text-slate-500">Enter your new secure password below.</p>
    </div>

    <div class="card">
        <div x-show="error" x-transition class="p-4 mb-6 bg-red-500/10 text-red-500 border border-red-500/20 rounded-xl text-sm font-semibold flex items-center gap-2" x-cloak>
            <i class="fa-solid fa-circle-exclamation"></i> <span x-text="error"></span>
        </div>

        <div x-show="success" x-transition class="p-4 mb-6 bg-primary/10 text-primary border border-primary/20 rounded-xl text-sm font-semibold text-center" x-cloak>
            <i class="fa-solid fa-check-circle mb-2 text-2xl block"></i>
            Password reset successfully! Redirecting to login...
        </div>

        <form @submit.prevent="submitForm" class="space-y-6" x-show="!success">
            
            <div class="input-group">
                <label>New Password</label>
                <input type="password" x-model="password" @input="validate" required class="input-field" placeholder="••••••••">
                <i class="fa-solid fa-key input-icon"></i>
            </div>

            <div class="bg-slate-50 dark:bg-slate-900 rounded-xl p-4 border border-slate-200 dark:border-slate-700">
                <div class="grid grid-cols-2 gap-2 text-xs font-medium">
                    <div class="flex items-center gap-2" :class="checks.length ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid fa-circle-check"></i> 8+ characters
                    </div>
                    <div class="flex items-center gap-2" :class="checks.upper ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid fa-circle-check"></i> Uppercase
                    </div>
                    <div class="flex items-center gap-2" :class="checks.number ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid fa-circle-check"></i> Number
                    </div>
                    <div class="flex items-center gap-2" :class="checks.special ? 'text-primary' : 'text-slate-400'">
                        <i class="fa-solid fa-circle-check"></i> Special char
                    </div>
                </div>
            </div>

            <div class="input-group">
                <label>Confirm Password</label>
                <input type="password" x-model="confirm" required class="input-field" placeholder="••••••••">
                <i class="fa-solid fa-lock input-icon"></i>
            </div>

            <button type="submit" class="btn-accent w-full mt-2" :disabled="loading || !isValid">
                <span x-show="!loading">Reset Password</span>
                <span x-show="loading"><i class="fa-solid fa-circle-notch fa-spin"></i> Processing...</span>
            </button>
        </form>
    </div>
</div>

<script>
function resetPasswordForm(token) {
    return {
        password: '', confirm: '', loading: false, error: '', success: false,
        checks: { length: false, upper: false, number: false, special: false },
        validate() {
            const p = this.password;
            this.checks.length = p.length >= 8;
            this.checks.upper = /[A-Z]/.test(p);
            this.checks.number = /[0-9]/.test(p);
            this.checks.special = /[@$!%*?&]/.test(p);
        },
        get isValid() {
            return Object.values(this.checks).every(Boolean) && this.password === this.confirm && this.password !== '';
        },
        async submitForm() {
            this.loading = true; this.error = '';
            try {
                const response = await fetch('/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token, password: this.password, confirmPassword: this.confirm }),
                });
                const data = await response.json();
                if (!response.ok) throw new Error(data.message || 'Password reset failed');
                
                this.success = true;
                setTimeout(() => { window.location.href = '/auth/login'; }, 2000);
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>