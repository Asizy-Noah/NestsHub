<%- include('../layout', { title, body: `
<div class="max-w-md mx-auto px-4 py-12" x-data="setPasswordForm('${accountId}')" x-cloak>
    <div class="card">
        <h1 class="text-3xl font-bold text-center mb-8">Set Your Password</h1>

        <!-- Error Messages -->
        <div x-show="error" class="alert-error mb-6">
            <span x-text="error"></span>
            <button @click="error = ''" class="float-right text-xl">&times;</button>
        </div>

        <!-- Success Message -->
        <div x-show="success" class="alert-success mb-6">
            Password set successfully! Redirecting to login...
        </div>

        <form @submit.prevent="submitForm()" class="space-y-6" x-show="!success">
            <div>
                <label class="block text-sm font-medium mb-2">New Password</label>
                <input 
                    type="password" 
                    x-model="formData.password" 
                    class="input-field"
                    placeholder="••••••••"
                    required
                    @input="validatePassword()"
                >
                <p class="text-xs text-gray-600 dark-mode:text-gray-400 mt-2">
                    Must be at least 8 characters with uppercase, lowercase, number, and special character
                </p>
                <div class="mt-2 space-y-1 text-xs">
                    <div :class="passwordChecks.length ? 'text-green-600' : 'text-red-600'">
                        ✓ At least 8 characters
                    </div>
                    <div :class="passwordChecks.upper ? 'text-green-600' : 'text-red-600'">
                        ✓ Uppercase letter
                    </div>
                    <div :class="passwordChecks.lower ? 'text-green-600' : 'text-red-600'">
                        ✓ Lowercase letter
                    </div>
                    <div :class="passwordChecks.number ? 'text-green-600' : 'text-red-600'">
                        ✓ Number
                    </div>
                    <div :class="passwordChecks.special ? 'text-green-600' : 'text-red-600'">
                        ✓ Special character (@$!%*?&)
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium mb-2">Confirm Password</label>
                <input 
                    type="password" 
                    x-model="formData.confirmPassword" 
                    class="input-field"
                    placeholder="••••••••"
                    required
                >
                <div x-show="formData.confirmPassword && formData.password !== formData.confirmPassword" class="text-red-600 text-sm mt-2">
                    Passwords do not match
                </div>
            </div>

            <button 
                type="submit" 
                class="btn-primary w-full"
                :disabled="loading || !isPasswordValid()"
                x-text="loading ? 'Setting Password...' : 'Set Password'"
            ></button>
        </form>
    </div>
</div>

<script>
function setPasswordForm(accountId) {
    return {
        loading: false,
        error: '',
        success: false,
        formData: {
            password: '',
            confirmPassword: '',
        },
        passwordChecks: {
            length: false,
            upper: false,
            lower: false,
            number: false,
            special: false,
        },

        validatePassword() {
            const pwd = this.formData.password;
            this.passwordChecks.length = pwd.length >= 8;
            this.passwordChecks.upper = /[A-Z]/.test(pwd);
            this.passwordChecks.lower = /[a-z]/.test(pwd);
            this.passwordChecks.number = /[0-9]/.test(pwd);
            this.passwordChecks.special = /[@$!%*?&]/.test(pwd);
        },

        isPasswordValid() {
            return Object.values(this.passwordChecks).every(v => v) && 
                   this.formData.password === this.formData.confirmPassword;
        },

        async submitForm() {
            this.loading = true;
            this.error = '';

            try {
                const response = await fetch('/auth/set-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        accountId,
                        password: this.formData.password,
                        confirmPassword: this.formData.confirmPassword,
                    }),
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.message || 'Failed to set password');
                }

                this.success = true;
                setTimeout(() => {
                    window.location.href = '/auth/login';
                }, 2000);
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>
`) %>
