<%- include('../layout') %>

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Hotel Manager Dashboard</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-2">Manage your hotel, rooms, and reservations</p>
    </div>

    <!-- Navigation Tabs -->
    <div x-data="{ activeTab: 'overview' }" class="mb-8">
      <div class="flex border-b border-slate-200 dark:border-slate-700">
        <button
          @click="activeTab = 'overview'"
          :class="activeTab === 'overview' ? 'border-b-2 border-indigo-600 text-indigo-600' : 'text-slate-600 dark:text-slate-400'"
          class="px-6 py-3 font-medium transition-colors"
        >
          Overview
        </button>
        <button
          @click="activeTab = 'profile'"
          :class="activeTab === 'profile' ? 'border-b-2 border-indigo-600 text-indigo-600' : 'text-slate-600 dark:text-slate-400'"
          class="px-6 py-3 font-medium transition-colors"
        >
          Hotel Profile
        </button>
        <button
          @click="activeTab = 'rooms'"
          :class="activeTab === 'rooms' ? 'border-b-2 border-indigo-600 text-indigo-600' : 'text-slate-600 dark:text-slate-400'"
          class="px-6 py-3 font-medium transition-colors"
        >
          Room Management
        </button>
        <button
          @click="activeTab = 'settings'"
          :class="activeTab === 'settings' ? 'border-b-2 border-indigo-600 text-indigo-600' : 'text-slate-600 dark:text-slate-400'"
          class="px-6 py-3 font-medium transition-colors"
        >
          Settings
        </button>
      </div>

      <!-- Overview Tab -->
      <div x-show="activeTab === 'overview'" class="mt-8 space-y-6">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Total Rooms</p>
                <p class="text-3xl font-bold text-slate-900 dark:text-white mt-2">48</p>
              </div>
              <div class="bg-indigo-100 dark:bg-indigo-900 rounded-lg p-3">
                <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Available</p>
                <p class="text-3xl font-bold text-emerald-600 dark:text-emerald-400 mt-2">32</p>
              </div>
              <div class="bg-emerald-100 dark:bg-emerald-900 rounded-lg p-3">
                <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Booked</p>
                <p class="text-3xl font-bold text-red-600 dark:text-red-400 mt-2">16</p>
              </div>
              <div class="bg-red-100 dark:bg-red-900 rounded-lg p-3">
                <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-slate-600 dark:text-slate-400 text-sm font-medium">Occupancy Rate</p>
                <p class="text-3xl font-bold text-blue-600 dark:text-blue-400 mt-2">33%</p>
              </div>
              <div class="bg-blue-100 dark:bg-blue-900 rounded-lg p-3">
                <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Verification Card -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Hotel Verification Status</h3>
              <div class="flex items-center gap-2 mt-3">
                <div class="w-3 h-3 bg-amber-500 rounded-full"></div>
                <span class="text-amber-600 dark:text-amber-400 font-medium">Pending Verification</span>
              </div>
              <p class="text-slate-600 dark:text-slate-400 text-sm mt-2">Your hotel is being reviewed by our team</p>
            </div>
            <button class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
              Apply Now
            </button>
          </div>
        </div>
      </div>

      <!-- Profile Tab -->
      <div x-show="activeTab === 'profile'" class="mt-8">
        <%- include('./partials/hotel-profile-form') %>
      </div>

      <!-- Rooms Tab -->
      <div x-show="activeTab === 'rooms'" class="mt-8">
        <%- include('./partials/room-management') %>
      </div>

      <!-- Settings Tab -->
      <div x-show="activeTab === 'settings'" class="mt-8">
        <%- include('./partials/hotel-settings') %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/toast-notification') %>
