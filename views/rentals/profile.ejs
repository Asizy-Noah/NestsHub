<div class="max-w-4xl mx-auto px-4 py-8" x-data="managerProfile(<%= typeof user !== 'undefined' ? JSON.stringify(user) : '{}' %>)">
    
    <div class="card space-y-8">
        <div class="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-6">
            <div>
                <h1 class="text-3xl font-black text-professional dark:text-white">My Identity</h1>
                <p class="text-slate-500 text-sm">How clients and the system see you.</p>
            </div>
            <div class="w-12 h-12 bg-primary/10 text-primary rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-id-card-clip"></i></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="flex flex-col items-center gap-4">
                <div class="w-40 h-40 rounded-full border-4 border-slate-100 dark:border-slate-800 overflow-hidden shadow-inner bg-slate-50 relative flex items-center justify-center">
                    <template x-if="profile.photo"><img :src="profile.photo" class="w-full h-full object-cover"></template>
                    <template x-if="!profile.photo"><i class="fa-solid fa-user text-5xl text-slate-300"></i></template>
                </div>
                <label class="btn-outline text-xs py-2 px-4 cursor-pointer">
                    Change Photo <input type="file" accept="image/*" class="hidden" @change="uploadPhoto">
                </label>
            </div>

            <div class="md:col-span-2 space-y-5">
                <div class="input-group">
                    <label>Identity Role</label>
                    <select x-model="profile.role" class="input-field font-black text-primary bg-primary/5 border-primary/20">
                        <option>Property Owner</option><option>Property Manager</option><option>Broker / Agent</option>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="input-group"><label>First Name</label><input type="text" x-model="profile.firstName" class="input-field font-bold"></div>
                    <div class="input-group"><label>Last Name</label><input type="text" x-model="profile.lastName" class="input-field font-bold"></div>
                </div>
                <div class="input-group"><label>Public Username</label><input type="text" x-model="profile.username" class="input-field bg-slate-100" placeholder="@username"></div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-6 border-t border-slate-100 dark:border-slate-800">
            <div class="space-y-3">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Phone Numbers</label>
                <template x-for="(phone, index) in profile.phones" :key="index">
                    <div class="flex gap-2"><input type="tel" x-model="profile.phones[index]" class="input-field py-2"><button @click="profile.phones.splice(index,1)" class="w-10 text-red-500 hover:bg-red-50 rounded-xl"><i class="fa-solid fa-trash"></i></button></div>
                </template>
                <button @click="profile.phones.push('')" class="text-xs font-bold text-primary"><i class="fa-solid fa-plus"></i> Add Phone</button>
            </div>
            
            <div class="space-y-3">
                <label class="text-xs font-bold text-emerald-500 uppercase tracking-wider block">WhatsApp</label>
                <template x-for="(wa, index) in profile.whatsapps" :key="index">
                    <div class="flex gap-2"><input type="tel" x-model="profile.whatsapps[index]" class="input-field py-2 border-emerald-200"><button @click="profile.whatsapps.splice(index,1)" class="w-10 text-red-500 hover:bg-red-50 rounded-xl"><i class="fa-solid fa-trash"></i></button></div>
                </template>
                <button @click="profile.whatsapps.push('')" class="text-xs font-bold text-emerald-600"><i class="fa-solid fa-plus"></i> Add WhatsApp</button>
            </div>

            <div class="space-y-3">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Emails</label>
                <template x-for="(email, index) in profile.emails" :key="index">
                    <div class="flex gap-2"><input type="email" x-model="profile.emails[index]" class="input-field py-2"><button @click="profile.emails.splice(index,1)" class="w-10 text-red-500 hover:bg-red-50 rounded-xl"><i class="fa-solid fa-trash"></i></button></div>
                </template>
                <button @click="profile.emails.push('')" class="text-xs font-bold text-primary"><i class="fa-solid fa-plus"></i> Add Email</button>
            </div>
        </div>

        <div class="space-y-4 pt-6 border-t border-slate-100 dark:border-slate-800">
            <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Areas of Operation (Locations)</label>
            <div class="flex flex-wrap gap-2">
                <template x-for="(area, index) in profile.areasOfOperation" :key="index">
                    <div class="bg-primary/10 border border-primary/20 text-primary font-bold px-4 py-2 rounded-full flex items-center gap-2">
                        <span x-text="area"></span>
                        <button @click="profile.areasOfOperation.splice(index,1)" class="w-4 h-4 rounded-full bg-primary text-white flex items-center justify-center text-[8px]"><i class="fa-solid fa-x"></i></button>
                    </div>
                </template>
                <div class="flex gap-2 items-center">
                    <input type="text" x-model="newArea" placeholder="e.g. Ntinda" class="input-field py-1.5 px-3 rounded-full w-40 text-sm">
                    <button @click="if(newArea.trim()) { profile.areasOfOperation.push(newArea); newArea = ''; }" class="w-8 h-8 bg-slate-800 text-white rounded-full text-xs shadow-md hover:bg-primary transition-colors"><i class="fa-solid fa-plus"></i></button>
                </div>
            </div>
        </div>

        <div class="pt-8">
            <button @click="saveProfile" class="btn-primary w-full md:w-auto px-10 shadow-xl" :disabled="saving">
                <span x-show="!saving">Save Identity Settings</span>
                <span x-show="saving"><i class="fa-solid fa-spinner fa-spin"></i> Updating...</span>
            </button>
        </div>
    </div>
</div>

<script>
function managerProfile(initialUser) {
    return {
        saving: false, newArea: '',
        profile: {
            role: initialUser.role || 'Property Manager', firstName: initialUser.firstName || '', lastName: initialUser.lastName || '', username: initialUser.username || '',
            photo: initialUser.photo || '', phones: initialUser.phones || [''], whatsapps: initialUser.whatsapps || [''], emails: initialUser.emails || [''],
            areasOfOperation: initialUser.areasOfOperation || ['Kampala']
        },
        init() {
            if(!this.profile.phones.length) this.profile.phones = [''];
            if(!this.profile.whatsapps.length) this.profile.whatsapps = [''];
            if(!this.profile.emails.length) this.profile.emails = [''];
        },
        uploadPhoto(e) {
            const file = e.target.files[0];
            if(file) {
                const reader = new FileReader();
                reader.onload = ev => this.profile.photo = ev.target.result;
                reader.readAsDataURL(file);
            }
        },
        async saveProfile() {
            // Clean arrays
            this.profile.phones = this.profile.phones.filter(p => p.trim());
            this.profile.whatsapps = this.profile.whatsapps.filter(w => w.trim());
            this.profile.emails = this.profile.emails.filter(e => e.trim());
            if(!this.profile.phones.length) this.profile.phones.push('');

            this.saving = true;
            try {
                const res = await fetch('/dashboard/rentals/profile/update', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${localStorage.getItem('accessToken')}` },
                    body: JSON.stringify(this.profile)
                });
                if(!res.ok) throw new Error();
                alert("Identity saved successfully.");
            } catch (e) {
                alert("Failed to save profile.");
            } finally {
                this.saving = false;
            }
        }
    }
}
</script>