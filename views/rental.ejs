<div x-data="brokerProfile()" class="bg-slate-50 dark:bg-dark-bg min-h-screen pb-24 sm:pb-8" x-cloak>
    
    <div class="bg-white dark:bg-dark-surface border-b border-slate-200 dark:border-slate-800 pt-8 pb-6 shadow-sm relative z-20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="flex justify-between items-center mb-6">
                <button @click="history.back()" class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 flex items-center justify-center hover:bg-slate-200 transition-colors">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
                <button class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 flex items-center justify-center hover:bg-slate-200 transition-colors">
                    <i class="fa-solid fa-share-nodes"></i>
                </button>
            </div>

            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 text-center sm:text-left">
                <div class="w-28 h-28 sm:w-32 sm:h-32 rounded-full bg-slate-100 dark:bg-slate-800 border-4 border-slate-50 dark:border-slate-900 shadow-md overflow-hidden relative">
                    <img :src="broker.photo || 'https://ui-avatars.com/api/?name=' + broker.firstName" class="w-full h-full object-cover">
                </div>

                <div class="flex-1 mt-2 sm:mt-4">
                    <h1 class="text-2xl sm:text-4xl font-black text-professional dark:text-white flex items-center justify-center sm:justify-start gap-2">
                        <span x-text="broker.firstName + ' ' + broker.lastName"></span>
                        <i class="fa-solid fa-circle-check text-primary text-sm mt-1" title="Verified ID"></i>
                    </h1>
                    <p class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4 mt-1" x-text="broker.role"></p>
                    
                    <div class="flex justify-center sm:justify-start gap-6 sm:gap-10">
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Listings</p>
                            <p class="text-xl font-black text-professional dark:text-white" x-text="rentals.length"></p>
                        </div>
                        <div class="w-px bg-slate-200 dark:bg-slate-700"></div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Rating</p>
                            <a href="#reviews" class="flex items-baseline gap-1 group">
                                <span class="text-xl font-black text-professional dark:text-white group-hover:text-primary transition-colors" x-text="stats.rating"></span>
                                <i class="fa-solid fa-star text-amber-400 text-xs"></i>
                            </a>
                        </div>
                        <div class="w-px bg-slate-200 dark:bg-slate-700"></div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Main Area</p>
                            <p class="text-sm font-black text-professional dark:text-white mt-1" x-text="broker.areasOfOperation[0] || 'Kampala'"></p>
                        </div>
                    </div>
                </div>

                <div class="w-full sm:w-auto mt-4 sm:mt-6">
                    <button @click="toggleFollow()" class="btn-primary w-full sm:w-auto px-8" :class="isFollowing ? 'bg-slate-800 hover:bg-slate-900' : ''">
                        <i class="fa-solid" :class="isFollowing ? 'fa-check' : 'fa-bell'"></i>
                        <span x-text="isFollowing ? 'Following Updates' : 'Follow Broker'"></span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="sticky top-0 z-30 bg-slate-50 dark:bg-dark-bg pt-4 pb-4 border-b border-slate-200 dark:border-slate-800 shadow-sm">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 overflow-x-auto hide-scrollbar">
            
            <div class="relative flex-shrink-0" x-data="{ open: false }">
                <button @click="open = !open" @click.outside="open = false" class="flex items-center gap-2 px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl font-bold text-sm hover:border-primary hover:text-primary transition-colors shadow-sm">
                    <span x-text="sortLabel"></span> <i class="fa-solid fa-chevron-down text-[10px]"></i>
                </button>
                </div>

            <button class="px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl font-semibold text-sm hover:border-primary transition-colors shadow-sm flex-shrink-0">1 Bedroom</button>
            <button class="px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl font-semibold text-sm hover:border-primary transition-colors shadow-sm flex-shrink-0">Bungalows</button>
            <button class="px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl font-semibold text-sm hover:border-primary transition-colors shadow-sm flex-shrink-0">Apartments</button>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4 pb-12">
            <template x-for="rental in rentals" :key="rental._id">
                <a :href="'/public/rentals/item/' + rental._id" class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-lg hover:border-primary/50 transition-all group flex flex-col h-full relative">
                    
                    <div class="relative w-full pt-[85%] bg-slate-100 dark:bg-slate-800 overflow-hidden">
                        <img :src="rental.unitPhotos[0]" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute top-2 left-2 bg-black/60 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold text-white shadow-sm" x-show="rental.availableUnits > 0">Available</div>
                    </div>
                    
                    <div class="p-3 flex flex-col flex-1">
                        <h4 class="font-bold text-sm text-professional dark:text-white line-clamp-2 leading-tight mb-1 group-hover:text-primary transition-colors" x-text="rental.category + ' in ' + rental.propertyType"></h4>
                        <p class="text-xs text-slate-500 font-medium mb-2 truncate"><i class="fa-solid fa-location-dot text-slate-300 mr-1"></i> <span x-text="rental.nearestTown + ', ' + rental.district"></span></p>
                        
                        <div class="mt-auto pt-2 border-t border-slate-100 dark:border-slate-800">
                            <span class="text-primary font-black text-sm sm:text-base leading-none">UGX <span x-text="(rental.price/1000).toFixed(0)"></span>K <span class="text-[10px] text-slate-400 font-bold uppercase block sm:inline mt-0.5 sm:mt-0" x-text="rental.rateType"></span></span>
                        </div>
                    </div>
                </a>
            </template>
        </div>
    </div>

    <div class="fixed bottom-0 inset-x-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl border-t border-slate-200 dark:border-slate-800 p-4 pb-safe flex justify-center shadow-[0_-10px_20px_rgba(0,0,0,0.05)]">
        <div class="w-full max-w-4xl flex gap-3">
            <a :href="`tel:${broker.phones[0]}`" class="flex-1 btn-primary py-3.5 shadow-lg bg-slate-800 hover:bg-black text-white">
                <i class="fa-solid fa-phone"></i> <span class="hidden sm:inline ml-2">Call Broker</span>
            </a>
            <a :href="`https://wa.me/${broker.whatsapps[0]}`" target="_blank" class="flex-1 bg-[#25D366] hover:bg-[#20bd5a] text-white rounded-xl py-3.5 flex items-center justify-center font-bold shadow-lg transition-colors">
                <i class="fa-brands fa-whatsapp text-lg"></i> <span class="hidden sm:inline ml-2">WhatsApp</span>
            </a>
            <button class="flex-1 btn-outline py-3.5 border-slate-200 bg-white dark:bg-slate-800 dark:border-slate-700 shadow-sm">
                <i class="fa-regular fa-comment-dots text-lg"></i> <span class="hidden sm:inline ml-2">Message</span>
            </button>
        </div>
    </div>

</div>

<script>
function brokerProfile() {
    return {
        isFollowing: false, sortLabel: 'Newest First',
        broker: { firstName: 'Robert', lastName: 'K.', role: 'Property Manager', photo: '', phones: ['0700000000'], whatsapps: ['0700000000'], areasOfOperation: ['Wakiso', 'Kampala'] },
        stats: { rating: 4.6, reviewCount: 42 },
        rentals: [
            { _id: 'r1', category: '2 Bedroom Apartment', propertyType: 'Flats', nearestTown: 'Najjera', district: 'Wakiso', price: 850000, rateType: 'Per Month', availableUnits: 1, unitPhotos: ['https://images.unsplash.com/photo-1502672260266-1c1e541818bd?w=400'] },
            { _id: 'r2', category: 'Single Room Self Contained', propertyType: 'Bungalow Annex', nearestTown: 'Kira', district: 'Wakiso', price: 350000, rateType: 'Per Month', availableUnits: 2, unitPhotos: ['https://images.unsplash.com/photo-1522771731470-ea43374b422a?w=400'] }
        ],
        toggleFollow() { this.isFollowing = !this.isFollowing; }
    }
}
</script>