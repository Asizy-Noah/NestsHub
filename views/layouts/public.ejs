<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= typeof title !== 'undefined' ? title + ' | NestHub' : 'NestHub - Find Your Perfect Space' %></title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#10B981',       // Emerald Green
                        professional: '#1E293B',  // Slate Blue
                        accent: '#F59E0B',        // Amber
                        'dark-bg': '#0B1120',
                        'dark-surface': '#0F172A',
                    },
                    boxShadow: {
                        'glass': '0 10px 40px -10px rgba(0,0,0,0.08)',
                        'nav': '0 4px 20px -2px rgba(0,0,0,0.05)'
                    }
                }
            }
        }
    </script>

    <style type="text/tailwindcss">
        @layer components {
            .btn-primary { @apply bg-primary text-white rounded-xl hover:bg-emerald-600 active:scale-[0.98] transition-all duration-200 shadow-md flex items-center justify-center font-bold; }
            .btn-icon { @apply w-10 h-10 rounded-full flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors relative; }
        }
        [x-cloak] { display: none !important; }
        
        /* Hide scrollbar for horizontal scrolling areas but keep functionality */
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Smooth scrolling behavior */
        html { scroll-behavior: smooth; }
    </style>
</head>
<body x-data="publicLayout()" 
      x-init="initLayout()" 
      @scroll.window="handleScroll"
      :class="isDark ? 'dark bg-dark-bg text-slate-200' : 'bg-slate-50 text-slate-800'" 
      class="antialiased overflow-x-hidden font-sans pb-20 md:pb-0" x-cloak>

    <header class="fixed top-0 inset-x-0 z-40 bg-white/95 dark:bg-slate-900/95 backdrop-blur-md transition-transform duration-300 border-b border-slate-100 dark:border-slate-800"
            :class="showTopNav ? 'translate-y-0 shadow-nav' : '-translate-y-full'">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            
            <a href="/" class="flex items-center gap-2 group">
                <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white shadow-sm group-hover:scale-105 transition-transform"><i class="fa-solid fa-house-chimney text-sm"></i></div>
                <span class="text-xl font-black text-professional dark:text-white tracking-tight">Nest<span class="text-primary">Hub</span></span>
            </a>

            <div class="flex items-center gap-2 sm:gap-4">
                <a href="/saved" class="btn-icon group">
                    <i class="fa-regular fa-heart text-xl group-hover:text-red-500 transition-colors"></i>
                    <span class="absolute top-1 right-1 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white dark:border-slate-900 hidden"></span>
                </a>

                <div class="relative" @click.outside="userMenuOpen = false">
                    <button @click="userMenuOpen = !userMenuOpen" class="btn-icon bg-slate-100 dark:bg-slate-800">
                        <i class="fa-regular fa-user text-xl text-primary"></i>
                    </button>

                    <div x-show="userMenuOpen" 
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 scale-95 translate-y-2"
                         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100 scale-100 translate-y-0"
                         x-transition:leave-end="opacity-0 scale-95 translate-y-2"
                         class="absolute right-0 mt-3 w-56 bg-white dark:bg-dark-surface rounded-2xl shadow-2xl border border-slate-100 dark:border-slate-800 overflow-hidden py-2">
                        
                        <div class="px-4 py-3 border-b border-slate-100 dark:border-slate-800/50">
                            <p class="text-sm font-bold text-professional dark:text-white">Welcome to NestHub</p>
                            <p class="text-xs text-slate-500">Sign in to manage bookings</p>
                        </div>
                        
                        <a href="/messages" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                            <i class="fa-regular fa-comment-dots w-5 text-center"></i> Messages
                        </a>
                        <a href="/bookings" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors border-b border-slate-100 dark:border-slate-800/50">
                            <i class="fa-solid fa-list-check w-5 text-center"></i> My Bookings
                        </a>

                        <button @click="toggleTheme" class="w-full flex items-center justify-between px-4 py-3 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                            <span class="flex items-center gap-3"><i class="fa-solid fa-moon w-5 text-center"></i> Dark Mode</span>
                            <div class="w-8 h-4 rounded-full relative transition-colors" :class="isDark ? 'bg-primary' : 'bg-slate-300'">
                                <div class="w-3 h-3 bg-white rounded-full absolute top-0.5 shadow transition-transform" :class="isDark ? 'translate-x-4' : 'translate-x-0.5'"></div>
                            </div>
                        </button>

                        <div class="pt-2 mt-2 border-t border-slate-100 dark:border-slate-800/50 px-2">
                            <a href="/auth/login" class="btn-primary w-full py-2.5 text-sm shadow-none">Sign In / Register</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="pt-16 min-h-screen">
        <%- body %>
    </main>

    <nav class="md:hidden fixed bottom-0 inset-x-0 z-40 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border-t border-slate-200 dark:border-slate-800 transition-transform duration-300 pb-safe"
         :class="showBottomNav ? 'translate-y-0 shadow-[0_-10px_20px_rgba(0,0,0,0.05)]' : 'translate-y-full'">
        <div class="flex justify-around items-center h-16 px-2">
            <a href="/" class="flex flex-col items-center justify-center w-16 h-full text-primary">
                <i class="fa-solid fa-compass text-xl mb-1"></i>
                <span class="text-[10px] font-bold">Explore</span>
            </a>
            <a href="/saved" class="flex flex-col items-center justify-center w-16 h-full text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-white transition-colors">
                <i class="fa-regular fa-heart text-xl mb-1"></i>
                <span class="text-[10px] font-bold">Saved</span>
            </a>
            <a href="/bookings" class="flex flex-col items-center justify-center w-16 h-full text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-white transition-colors">
                <i class="fa-solid fa-list-check text-xl mb-1"></i>
                <span class="text-[10px] font-bold">Bookings</span>
            </a>
            <a href="/messages" class="flex flex-col items-center justify-center w-16 h-full text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-white transition-colors relative">
                <i class="fa-regular fa-comment-dots text-xl mb-1"></i>
                <span class="text-[10px] font-bold">Inbox</span>
                <span class="absolute top-2 right-3 w-2.5 h-2.5 bg-primary rounded-full border-2 border-white dark:border-slate-900 hidden"></span>
            </a>
        </div>
    </nav>

    <script>
        function publicLayout() {
            return {
                isDark: false,
                userMenuOpen: false,
                showTopNav: true,
                showBottomNav: true,
                lastScrollY: 0,
                
                initLayout() {
                    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                        this.isDark = true;
                    }
                },
                toggleTheme() {
                    this.isDark = !this.isDark;
                    localStorage.setItem('theme', this.isDark ? 'dark' : 'light');
                },
                handleScroll() {
                    const currentScrollY = window.scrollY;
                    const threshold = 50; // Don't trigger hide/show on tiny scrolls
                    
                    if (currentScrollY > this.lastScrollY && currentScrollY > 100) {
                        // Scrolling DOWN
                        this.showTopNav = false;
                        this.showBottomNav = false;
                        this.userMenuOpen = false; // Auto-close menu on scroll
                    } else if (currentScrollY < this.lastScrollY - 10 || currentScrollY <= 50) {
                        // Scrolling UP or at Top
                        this.showTopNav = true;
                        this.showBottomNav = true;
                    }
                    this.lastScrollY = currentScrollY;
                }
            }
        }
    </script>
</body>
</html>