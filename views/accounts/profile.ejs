<div class="max-w-4xl mx-auto p-4 sm:p-8" x-data="profileManager()">
    <div class="card space-y-8">
        <div class="border-b border-slate-100 dark:border-slate-800 pb-6 flex justify-between items-end">
            <div>
                <h2 class="text-2xl font-black text-professional dark:text-white">Account Identity</h2>
                <p class="text-slate-500 text-sm">Update your personal and contact details.</p>
            </div>
            <div class="text-right">
                <span class="text-[10px] font-black bg-primary/10 text-primary px-3 py-1 rounded-full uppercase">Manager Since: <span x-text="user.startedDate || 'N/A'"></span></span>
            </div>
        </div>

        <form @submit.prevent="updateProfile" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="input-group">
                    <label>First Name</label>
                    <input type="text" x-model="user.firstName" class="input-field">
                </div>
                <div class="input-group">
                    <label>Last Name</label>
                    <input type="text" x-model="user.lastName" class="input-field">
                </div>
                <div class="input-group">
                    <label>Nationality</label>
                    <input type="text" x-model="user.nationality" class="input-field">
                </div>
                <div class="input-group">
                    <label>Physical Address</label>
                    <input type="text" x-model="user.address" class="input-field" placeholder="City, Street">
                </div>
            </div>

            <div class="space-y-4">
                <label class="text-sm font-bold text-slate-700">Mobile Contacts</label>
                <template x-for="(phone, index) in user.phones" :key="index">
                    <div class="flex gap-2">
                        <input type="tel" x-model="user.phones[index]" class="input-field py-2">
                        <button type="button" @click="user.phones.splice(index,1)" class="w-10 text-red-500"><i class="fa-solid fa-trash-can"></i></button>
                    </div>
                </template>
                <button type="button" @click="user.phones.push('')" class="btn-outline text-xs py-2"><i class="fa-solid fa-plus"></i> Add Phone</button>
            </div>

            <button type="submit" class="btn-primary w-full md:w-auto" :disabled="saving">
                <span x-show="!saving">Save Account Changes</span>
                <span x-show="saving"><i class="fa-solid fa-spinner fa-spin"></i> Processing...</span>
            </button>
        </form>
    </div>
</div>